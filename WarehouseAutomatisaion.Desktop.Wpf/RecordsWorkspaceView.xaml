<UserControl x:Class="WarehouseAutomatisaion.Desktop.Wpf.RecordsWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#F7F9FF">
    <UserControl.Resources>
        <Style x:Key="PageCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E8EDF8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource TopActionButtonStyle}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E4EAF5" />
            <Setter Property="Foreground" Value="#4D5B79" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource TopPrimaryActionButtonStyle}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="#4F5BFF" />
            <Setter Property="BorderBrush" Value="#4F5BFF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="IconCircleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E4EAF5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#6A7898" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFF" />
                    <Setter Property="BorderBrush" Value="#C6D1F7" />
                    <Setter Property="Foreground" Value="#4F5BFF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#EEF2FF" />
                    <Setter Property="BorderBrush" Value="#9CADFF" />
                    <Setter Property="Foreground" Value="#3742D6" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Cursor" Value="Arrow" />
                    <Setter Property="Opacity" Value="0.62" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF2FA" />
            <Setter Property="VerticalGridLinesBrush" Value="#EEF2FA" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="RowHeight" Value="52" />
            <Setter Property="ColumnHeaderHeight" Value="42" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="EnableRowVirtualization" Value="True" />
            <Setter Property="EnableColumnVirtualization" Value="True" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#EEF2FA" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="#8A95B1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,0,14,0" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#EEF2FA" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="#1B2440" />
            <Setter Property="FontSize" Value="13" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FBFCFF" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#F5F7FF" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled" Background="#F7F9FF">
        <Grid Margin="28,22,28,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid x:Name="HeaderGrid" Grid.Row="0" Margin="0,0,0,22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="TitleText"
                               FontSize="34"
                               FontWeight="SemiBold"
                               Foreground="#1A2440" />
                    <TextBlock x:Name="SubtitleText"
                               Margin="0,8,0,0"
                               FontSize="15"
                               Foreground="#7280A0"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel x:Name="HeaderActionsPanel" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Border x:Name="HeaderSearchBorder" Width="320"
                                Height="40"
                                Background="#FFFFFF"
                                BorderBrush="#E4EAF5"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14,0,12,0">
                            <Grid>
                                <TextBox x:Name="HeaderSearchBox"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="14"
                                         Foreground="#1B2440"
                                         VerticalContentAlignment="Center"
                                         TextChanged="HandleHeaderSearchTextChanged" />
                                <TextBlock x:Name="HeaderSearchPlaceholderText"
                                           Text="Поиск..."
                                           FontSize="14"
                                           Foreground="#9AA5BD"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False" />
                                <TextBlock FontFamily="Segoe Fluent Icons"
                                           Text="&#xE721;"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Foreground="#909AB5"
                                           FontSize="13" />
                            </Grid>
                        </Border>
                        <Button Style="{StaticResource IconCircleButtonStyle}" Visibility="Collapsed">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE7F4;" FontSize="14" />
                        </Button>
                        <Button Style="{StaticResource IconCircleButtonStyle}" Visibility="Collapsed">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE897;" FontSize="14" />
                        </Button>
                    </StackPanel>

                    <WrapPanel HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button x:Name="ImportButton"
                                Style="{StaticResource GhostButtonStyle}"
                                Margin="0,0,10,0"
                                Click="HandleImportClick">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE8E5;" FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Text="Импорт" Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="PrimaryActionButton"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="HandlePrimaryActionClick" />
                    </WrapPanel>
                </StackPanel>
            </Grid>

            <ItemsControl x:Name="MetricsItemsControl" Grid.Row="1" Margin="0,0,0,24">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="176"
                                MinHeight="118"
                                Margin="0,0,14,14"
                                Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Style="{StaticResource MetricIconBoxStyle}"
                                            Background="{Binding IconBackground}"
                                            Width="34"
                                            Height="34">
                                        <TextBlock Text="{Binding IconGlyph}"
                                                   Style="{StaticResource MetricIconTextStyle}"
                                                   FontSize="16"
                                                   Foreground="{Binding AccentBrush}" />
                                    </Border>
                                    <TextBlock Text="{Binding Title}"
                                               Margin="12,6,0,0"
                                               MaxHeight="34"
                                               Style="{StaticResource MetricCaptionStyle}" />
                                </StackPanel>
                                <TextBlock Text="{Binding Value}"
                                           Margin="0,12,0,0"
                                           Style="{StaticResource MetricValueStyle}" />
                                <TextBlock Text="{Binding Delta}"
                                           Margin="0,10,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding DeltaBrush}"
                                           Style="{StaticResource MetricHintStyle}" />
                                <TextBlock Text="{Binding Hint}"
                                           Margin="0,2,0,0"
                                           TextWrapping="Wrap"
                                           MaxHeight="32"
                                           Style="{StaticResource MetricHintStyle}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="GroupTreePanel"
                        Grid.Column="0"
                        Width="270"
                        Padding="14"
                        Style="{StaticResource PageCardStyle}"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="GroupTreeTitleText"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#1A2440"
                                   Margin="4,2,4,12"
                                   Text="Папки" />

                        <TreeView x:Name="GroupTreeView"
                                  Grid.Row="1"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  SelectedItemChanged="HandleGroupTreeSelectedItemChanged">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="{x:Type TreeViewItem}">
                                    <Setter Property="IsExpanded" Value="True" />
                                    <Setter Property="Padding" Value="0,2" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" MinHeight="28">
                                        <TextBlock FontFamily="Segoe Fluent Icons"
                                                   Text="{Binding IconGlyph}"
                                                   Foreground="#6D7AFF"
                                                   FontSize="13"
                                                   Width="20"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="#1B2440"
                                                   FontSize="13"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding CountText}"
                                                   Foreground="#8A95B1"
                                                   FontSize="12"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>
                </Border>

                <Border x:Name="GroupTreeSpacer"
                        Grid.Column="1"
                        Width="16"
                        Visibility="Collapsed" />

                <Border Grid.Column="2" Padding="0" Style="{StaticResource PageCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="60" />
                        </Grid.RowDefinitions>

                        <WrapPanel Margin="18,16,18,16" VerticalAlignment="Center">
                            <ComboBox x:Name="PrimaryFilterCombo"
                                      Width="150"
                                      Style="{StaticResource TableFilterComboBoxStyle}"
                                      SelectionChanged="HandleFilterChanged" />
                            <StackPanel x:Name="DateRangePanel" Orientation="Horizontal" Margin="12,0,0,0" Visibility="Collapsed">
                                <DatePicker x:Name="StartDatePicker"
                                            Width="128"
                                            Style="{StaticResource TableFilterDatePickerStyle}"
                                            SelectedDateChanged="HandleDateFilterChanged" />
                                <DatePicker x:Name="EndDatePicker"
                                            Width="128"
                                            Style="{StaticResource TableFilterDatePickerStyle}"
                                            Margin="10,0,0,0"
                                            SelectedDateChanged="HandleDateFilterChanged" />
                            </StackPanel>
                            <Button x:Name="FilterButton"
                                    Margin="12,0,0,0"
                                    Style="{StaticResource TableFilterActionButtonStyle}"
                                    Content="Фильтры"
                                    Click="HandleFilterButtonClick" />
                        </WrapPanel>

                        <Grid Grid.Row="1">
                            <DataGrid x:Name="RecordsGrid"
                                      ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                            <TextBlock x:Name="EmptyStateText"
                                       Text="Нет данных"
                                       Style="{StaticResource TableEmptyTitleStyle}"
                                       Visibility="Collapsed"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>

                        <Grid Grid.Row="2" Style="{StaticResource TableFooterGridStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="FooterCountText"
                                       Style="{StaticResource TableFooterTextStyle}" />

                            <WrapPanel x:Name="PaginationPanel"
                                       Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Orientation="Horizontal" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
