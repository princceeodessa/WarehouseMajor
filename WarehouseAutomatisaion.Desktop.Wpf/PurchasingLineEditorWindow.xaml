<Window x:Class="WarehouseAutomatisaion.Desktop.Wpf.PurchasingLineEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Позиция закупки"
        Height="500"
        Width="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F7F9FD">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBrush" Color="#F7F9FD" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="LineBrush" Color="#E7ECF7" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#4F5BFF" />
        <SolidColorBrush x:Key="TextBrush" Color="#17213A" />
        <SolidColorBrush x:Key="MutedBrush" Color="#7A86A5" />

        <Style x:Key="CardStyle" TargetType="Border" BasedOn="{StaticResource DialogCardStyle}">
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource DialogFieldLabelStyle}" />

        <Style x:Key="InputStyle" TargetType="Control" BasedOn="{StaticResource DialogInputStyle}" />

        <Style x:Key="TextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource DialogTextBoxStyle}" />

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource DialogComboBoxStyle}">
            <Setter Property="IsEditable" Value="False" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogPrimaryButtonStyle}" />

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogSecondaryButtonStyle}" />
    </Window.Resources>

    <Grid Background="{StaticResource PageBrush}" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="4,0,4,18">
            <TextBlock x:Name="HeaderTitleText" FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
            <TextBlock x:Name="HeaderSubtitleText" Margin="0,6,0,0" FontSize="13.5" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,14">
                    <TextBlock Text="Номенклатура" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="ItemComboBox" Style="{StaticResource ComboBoxStyle}" SelectionChanged="HandleItemSelectionChanged" DisplayMemberPath="Label" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,14">
                    <TextBlock Text="Код" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="CodeTextBox" Style="{StaticResource TextBoxStyle}" IsReadOnly="True" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,14">
                    <TextBlock Text="Количество" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="QuantityTextBox" Style="{StaticResource TextBoxStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,14">
                    <TextBlock Text="Ед. изм." Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="UnitTextBox" Style="{StaticResource TextBoxStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,14">
                    <TextBlock Text="Цена" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="PriceTextBox" Style="{StaticResource TextBoxStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,14">
                    <TextBlock Text="Плановая дата" Style="{StaticResource FieldLabelStyle}" />
                    <DatePicker x:Name="PlannedDatePicker" Style="{StaticResource DialogDatePickerStyle}" />
                </StackPanel>

                <StackPanel x:Name="TargetLocationPanel" Grid.Row="3" Grid.ColumnSpan="2" Margin="0,0,0,14">
                    <TextBlock Text="Ячейка размещения" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="TargetLocationTextBox" Style="{StaticResource ComboBoxStyle}" IsEditable="True" IsTextSearchEnabled="False" />
                </StackPanel>

                <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Margin="0,0,0,14">
                    <TextBlock Text="Связанный документ" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="RelatedDocumentTextBox" Style="{StaticResource TextBoxStyle}" />
                </StackPanel>

                <TextBlock x:Name="ValidationText" Grid.Row="5" Grid.ColumnSpan="2" Foreground="#E14B5A" FontSize="12.5" TextWrapping="Wrap" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Отмена" Style="{StaticResource GhostButtonStyle}" Margin="0,0,10,0" Click="HandleCancelClick" />
            <Button Content="Сохранить" Style="{StaticResource PrimaryButtonStyle}" Click="HandleSaveClick" />
        </StackPanel>
    </Grid>
</Window>
