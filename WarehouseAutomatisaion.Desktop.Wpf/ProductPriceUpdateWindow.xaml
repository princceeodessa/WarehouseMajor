<Window x:Class="WarehouseAutomatisaion.Desktop.Wpf.ProductPriceUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Обновить цены"
        Width="520"
        Height="360"
        MinWidth="500"
        MinHeight="330"
        WindowStartupLocation="CenterOwner"
        Background="#F7F9FD">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock Text="Обновить цены"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#17213A" />
            <TextBlock x:Name="ProductsCountText"
                       Margin="0,6,0,0"
                       FontSize="13"
                       Foreground="#6E7B98" />
        </StackPanel>

        <Border Grid.Row="1"
                Style="{StaticResource DialogCardStyle}"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Вид цены" Style="{StaticResource DialogFieldLabelStyle}" />
                <ComboBox x:Name="PriceTypeComboBox" Grid.Row="1" Style="{StaticResource DialogComboBoxStyle}" Margin="0,0,0,14" />

                <TextBlock Grid.Row="2" Text="Причина изменения" Style="{StaticResource DialogFieldLabelStyle}" />
                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,14">
                    <ComboBox x:Name="ModeComboBox" Style="{StaticResource DialogComboBoxStyle}" Width="220" Margin="0,0,12,0" />
                    <TextBox x:Name="ValueTextBox" Style="{StaticResource DialogTextBoxStyle}" Width="160" />
                </StackPanel>

                <CheckBox x:Name="ApplyImmediatelyCheckBox"
                          Grid.Row="4"
                          Content="Сразу провести документ и обновить текущую цену"
                          IsChecked="True"
                          FontSize="13"
                          Foreground="#34415F" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <TextBlock x:Name="ValidationText"
                       Foreground="#D92D20"
                       VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена"
                        Style="{StaticResource DialogSecondaryButtonStyle}"
                        Width="120"
                        Margin="0,0,10,0"
                        Click="HandleCancelClick" />
                <Button Content="Сохранить цены"
                        Style="{StaticResource DialogPrimaryButtonStyle}"
                        Width="160"
                        Click="HandleSaveClick" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
