<Application x:Class="WarehouseAutomatisaion.Desktop.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <Style TargetType="{x:Type Button}">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <Style x:Key="TopActionButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DDE5F4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#34415F" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#8EA0FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFF" />
                    <Setter Property="BorderBrush" Value="#C6D1F7" />
                    <Setter Property="Foreground" Value="#24314F" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#EEF2FF" />
                    <Setter Property="BorderBrush" Value="#9CADFF" />
                    <Setter Property="Foreground" Value="#1B2440" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#F4F6FB" />
                    <Setter Property="BorderBrush" Value="#E2E7F2" />
                    <Setter Property="Foreground" Value="#9AA6BD" />
                    <Setter Property="Cursor" Value="Arrow" />
                    <Setter Property="Opacity" Value="0.62" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TopPrimaryActionButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TopActionButtonStyle}">
            <Setter Property="Background" Value="#4F5BFF" />
            <Setter Property="BorderBrush" Value="#4F5BFF" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4350F0" />
                    <Setter Property="BorderBrush" Value="#4350F0" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#3742D6" />
                    <Setter Property="BorderBrush" Value="#3742D6" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#AEB6E8" />
                    <Setter Property="BorderBrush" Value="#AEB6E8" />
                    <Setter Property="Foreground" Value="#F7F8FF" />
                    <Setter Property="Opacity" Value="0.68" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TopSearchContainerStyle" TargetType="{x:Type Border}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DDE5F4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,0,12,0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="TopSearchTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#1B2440" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="VerticalScrollBarVisibility" Value="Hidden" />
        </Style>

        <Style x:Key="TopSearchPlaceholderStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Foreground" Value="#97A2BB" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="TopSearchIconStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="Text" Value="&#xE721;" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#7E8AA6" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="TableFilterSearchContainerStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource TopSearchContainerStyle}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="12,0,12,0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <Style x:Key="TableFilterSearchTextBoxStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource TopSearchTextBoxStyle}" />

        <Style x:Key="TableFilterSearchPlaceholderStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource TopSearchPlaceholderStyle}" />

        <Style x:Key="TableFilterSearchIconStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource TopSearchIconStyle}" />

        <Style x:Key="TableFilterComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="118" />
            <Setter Property="Padding" Value="12,0,8,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DDE5F4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#1B2440" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="TableFilterDatePickerStyle" TargetType="{x:Type DatePicker}">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="128" />
            <Setter Property="Padding" Value="8,0,8,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DDE5F4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#1B2440" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="TableFilterActionButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TopActionButtonStyle}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="14,0" />
        </Style>

        <Style x:Key="TableFilterResetButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TableFilterActionButtonStyle}" />

        <Style x:Key="TableBulkBarStyle" TargetType="{x:Type Border}">
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Background" Value="#F4F6FF" />
            <Setter Property="BorderBrush" Value="#E2E8FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <Style x:Key="TableBulkTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1B2440" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TableBulkActionButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TableFilterActionButtonStyle}">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="TableBulkCloseButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TopActionButtonStyle}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#6E7B98" />
            <Setter Property="FontSize" Value="16" />
        </Style>

        <Style x:Key="TableRowActionButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TopActionButtonStyle}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E1E7F3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#64718F" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="TableRowActionIconStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="Text" Value="&#xE712;" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#64718F" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="{x:Type ContextMenu}">
            <Setter Property="Padding" Value="6" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DDE5F4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Foreground" Value="#1B2440" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="{x:Type Separator}">
            <Setter Property="Margin" Value="4,6" />
        </Style>

        <Style x:Key="DialogCardStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E4EAF5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <Style x:Key="DialogFieldLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Foreground" Value="#6E7B98" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="DialogInputStyle" TargetType="{x:Type Control}">
            <Setter Property="Height" Value="40" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Foreground" Value="#17213A" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DDE5F4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <Style x:Key="DialogTextBoxStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource DialogInputStyle}">
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="VerticalScrollBarVisibility" Value="Hidden" />
        </Style>

        <Style x:Key="DialogMultilineTextBoxStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource DialogTextBoxStyle}">
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="Padding" Value="12,10" />
        </Style>

        <Style x:Key="DialogComboBoxStyle" TargetType="{x:Type ComboBox}" BasedOn="{StaticResource DialogInputStyle}">
            <Setter Property="Padding" Value="12,0,8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="DialogDatePickerStyle" TargetType="{x:Type DatePicker}" BasedOn="{StaticResource DialogInputStyle}" />

        <Style x:Key="DialogPrimaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TopPrimaryActionButtonStyle}">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="DialogSecondaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TopActionButtonStyle}">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="DialogDataGridStyle" TargetType="{x:Type DataGrid}">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF2FA" />
            <Setter Property="VerticalGridLinesBrush" Value="#EEF2FA" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="RowHeight" Value="46" />
            <Setter Property="ColumnHeaderHeight" Value="40" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden" />
        </Style>

        <Style x:Key="DialogDataGridHeaderStyle" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#EEF2FA" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="#73809C" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,0" />
        </Style>

        <Style x:Key="TableFooterGridStyle" TargetType="{x:Type Grid}">
            <Setter Property="Margin" Value="18,0,18,0" />
            <Setter Property="MinHeight" Value="56" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <Style x:Key="TableFooterDockPanelStyle" TargetType="{x:Type DockPanel}">
            <Setter Property="Margin" Value="16,12,16,0" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="LastChildFill" Value="True" />
        </Style>

        <Style x:Key="TableFooterTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Foreground" Value="#7A86A5" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TablePagerPanelStyle" TargetType="{x:Type StackPanel}">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TablePagerButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TopActionButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DDE5F4" />
            <Setter Property="Foreground" Value="#53617E" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="TablePagerActiveButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TablePagerButtonStyle}">
            <Setter Property="Background" Value="#EEF2FF" />
            <Setter Property="BorderBrush" Value="#D7DFFE" />
            <Setter Property="Foreground" Value="#4F5BFF" />
        </Style>

        <Style x:Key="TablePagerEllipsisTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="2,0,10,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#98A3BC" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TablePagerIndicatorStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#EEF2FF" />
            <Setter Property="BorderBrush" Value="#D7DFFE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="TablePagerIndicatorTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#4F5BFF" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TablePageSizeComboBoxStyle" TargetType="{x:Type ComboBox}" BasedOn="{StaticResource TableFilterComboBoxStyle}">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="10,0,8,0" />
        </Style>

        <Style x:Key="TableEmptyOverlayStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>

        <Style x:Key="TableEmptyIconBoxStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="96" />
            <Setter Property="Height" Value="96" />
            <Setter Property="Background" Value="#F3F6FF" />
            <Setter Property="CornerRadius" Value="48" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>

        <Style x:Key="TableEmptyIconTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="42" />
            <Setter Property="Foreground" Value="#A9B7F7" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TableEmptyTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#21304B" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="TableEmptyHintStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Foreground" Value="#7A86A5" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="TopHeaderGridStyle" TargetType="{x:Type Grid}">
            <Setter Property="Margin" Value="0,0,0,22" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <Style x:Key="TopHeaderTextPanelStyle" TargetType="{x:Type StackPanel}">
            <Setter Property="Margin" Value="0,0,24,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TopHeaderTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="32" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#17213A" />
        </Style>

        <Style x:Key="TopHeaderSubtitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="0,7,0,0" />
            <Setter Property="FontSize" Value="14.5" />
            <Setter Property="Foreground" Value="#7A86A5" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="TopHeaderActionsWrapPanelStyle" TargetType="{x:Type WrapPanel}">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TopHeaderActionsGridStyle" TargetType="{x:Type Grid}">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="{x:Type Border}">
            <Setter Property="MinHeight" Value="104" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E7ECF7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <Style x:Key="MetricIconBoxStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style x:Key="MetricIconTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#17213A" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
            <Setter Property="LineHeight" Value="26" />
        </Style>

        <Style x:Key="MetricValueCompactStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MetricValueStyle}">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="LineHeight" Value="21" />
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="0,3,0,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#17213A" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="MetricHintStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#7A86A5" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="MetricCaptionStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Foreground" Value="#7A86A5" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style TargetType="{x:Type ScrollViewer}">
            <Setter Property="VerticalScrollBarVisibility" Value="Hidden" />
        </Style>

        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden" />
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="VerticalScrollBarVisibility" Value="Hidden" />
        </Style>
    </Application.Resources>
</Application>
