<UserControl x:Class="WarehouseAutomatisaion.Desktop.Wpf.WarehouseWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             mc:Ignorable="d"
             Background="#F7F9FD">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PageBrush" Color="#F7F9FD" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#E8EDF7" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#4F5BFF" />
        <SolidColorBrush x:Key="PrimarySoftBrush" Color="#EEF2FF" />
        <SolidColorBrush x:Key="TextBrush" Color="#1B2440" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#6E7B98" />
        <SolidColorBrush x:Key="MutedBrush" Color="#98A3BC" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#26A85B" />
        <SolidColorBrush x:Key="WarningBrush" Color="#FF9F1A" />
        <SolidColorBrush x:Key="DangerBrush" Color="#FF5B5B" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource TopActionButtonStyle}">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E4EAF5" />
            <Setter Property="Foreground" Value="#44506C" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource TopPrimaryActionButtonStyle}">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="SectionTabStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="Foreground" Value="#6E7B98" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="0,0,0,15" />
            <Setter Property="Margin" Value="0,0,34,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#4F5BFF" />
                    <Setter Property="BorderBrush" Value="#C8D1FF" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#A9B3C7" />
                    <Setter Property="Cursor" Value="Arrow" />
                    <Setter Property="Opacity" Value="0.64" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FilterComboStyle" TargetType="ComboBox" BasedOn="{StaticResource TableFilterComboBoxStyle}">
            <Setter Property="MinWidth" Value="118" />
        </Style>

        <Style x:Key="StockGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserResizeColumns" Value="False" />
            <Setter Property="CanUserSortColumns" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF2FA" />
            <Setter Property="VerticalGridLinesBrush" Value="#EEF2FA" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="RowHeight" Value="66" />
            <Setter Property="ColumnHeaderHeight" Value="44" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="EnableRowVirtualization" Value="True" />
            <Setter Property="EnableColumnVirtualization" Value="True" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        </Style>

        <Style x:Key="GridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#EEF2FA" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="#73809C" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,0,12,0" />
        </Style>

        <Style x:Key="GridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#EEF2FA" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="#1B2440" />
            <Setter Property="FontSize" Value="14" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FAFBFF" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#F4F7FF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="QuickActionButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="14,0" />
        </Style>

        <Style x:Key="ProblemsOnlyStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#44506C" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="SwitchTrack"
                                    Width="34"
                                    Height="20"
                                    CornerRadius="10"
                                    Background="#D8DEEC"
                                    Margin="0,0,10,0">
                                <Ellipse x:Name="SwitchThumb"
                                         Width="14"
                                         Height="14"
                                         Fill="#FFFFFF"
                                         HorizontalAlignment="Left"
                                         Margin="3,3,0,3" />
                            </Border>
                            <ContentPresenter VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#4F5BFF" />
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="0,3,3,3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Hidden"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="{StaticResource PageBrush}">
        <Grid Margin="28,24,28,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid x:Name="HeroGrid" Grid.Row="0" Style="{StaticResource TopHeaderGridStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="760" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Style="{StaticResource TopHeaderTextPanelStyle}">
                    <TextBlock Text="Склад"
                               Style="{StaticResource TopHeaderTitleStyle}" />
                    <TextBlock Text="Остатки, перемещения, резервы и инвентаризация"
                               Style="{StaticResource TopHeaderSubtitleStyle}" />

                    <StackPanel Orientation="Horizontal" Margin="0,22,0,0" VerticalAlignment="Center">
                        <TextBlock FontFamily="Segoe Fluent Icons"
                                   Text="&#xE7F8;"
                                   FontSize="14"
                                   Foreground="#73809C"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="PrimaryWarehouseText"
                                   Margin="8,0,0,0"
                                   FontSize="14"
                                   Foreground="#50607F"
                                   VerticalAlignment="Center" />

                        <Ellipse Width="8" Height="8" Fill="#34B267" Margin="18,0,0,0" VerticalAlignment="Center" />
                        <TextBlock x:Name="OperatorText"
                                   Margin="12,0,0,0"
                                   FontSize="14"
                                   Foreground="#50607F"
                                   VerticalAlignment="Center" />

                        <TextBlock FontFamily="Segoe Fluent Icons"
                                   Text="&#xE895;"
                                   FontSize="14"
                                   Foreground="#73809C"
                                   Margin="18,0,0,0"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="UpdatedAtText"
                                   Margin="10,0,0,0"
                                   FontSize="14"
                                   Foreground="#50607F"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <Grid x:Name="HeroActionsGrid" Grid.Row="0" Grid.Column="1" Style="{StaticResource TopHeaderActionsGridStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource TopSearchContainerStyle}"
                            Margin="0,0,12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="HeroSearchBox"
                                     Style="{StaticResource TopSearchTextBoxStyle}"
                                     TextChanged="HandleHeroSearchTextChanged" />
                            <TextBlock x:Name="HeroSearchPlaceholder"
                                       Text="Поиск по товару, коду или штрихкоду..."
                                       Style="{StaticResource TopSearchPlaceholderStyle}" />
                            <TextBlock Grid.Column="1"
                                       Style="{StaticResource TopSearchIconStyle}" />
                        </Grid>
                    </Border>

                    <Button x:Name="ImportButton"
                            Grid.Column="1"
                            Width="104"
                            Margin="0,0,12,0"
                            Style="{StaticResource TopActionButtonStyle}"
                            AutomationProperties.Name="Импорт склада"
                            Click="HandleImportClick">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock FontFamily="Segoe Fluent Icons"
                                       Text="&#xE896;"
                                       FontSize="14"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Импорт" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="ExportButton"
                            Grid.Column="2"
                            Width="104"
                            Margin="0,0,12,0"
                            Style="{StaticResource TopActionButtonStyle}"
                            AutomationProperties.Name="Экспорт склада"
                            Click="HandleExportClick">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock FontFamily="Segoe Fluent Icons"
                                       Text="&#xE8A7;"
                                       FontSize="14"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Экспорт" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="CreateButton"
                            Grid.Column="3"
                            Width="170"
                            Margin="0,0,12,0"
                            Style="{StaticResource TopPrimaryActionButtonStyle}"
                            AutomationProperties.Name="Создать складской документ"
                            Click="HandleCreateClick">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock FontFamily="Segoe Fluent Icons"
                                       Text="&#xE710;"
                                       FontSize="14"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Новое перемещение" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="ActionsButton"
                            Grid.Column="4"
                            Width="116"
                            Style="{StaticResource TopActionButtonStyle}"
                            AutomationProperties.Name="Действия склада"
                            Click="HandleActionsClick">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Действия" VerticalAlignment="Center" />
                            <TextBlock Margin="8,0,0,0"
                                       FontFamily="Segoe Fluent Icons"
                                       Text="&#xE70D;"
                                       FontSize="10"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>

            <WrapPanel x:Name="MetricsPanel" Grid.Row="1" Margin="0,0,0,22">
                <Border Width="252"
                        Margin="0,0,14,14"
                        Style="{StaticResource MetricCardStyle}"
                        Cursor="Hand"
                        Tag="critical"
                        MouseLeftButtonUp="HandleMetricCardClick">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource MetricIconBoxStyle}" Background="#FFF2F2">
                            <TextBlock Style="{StaticResource MetricIconTextStyle}"
                                       Text="&#xE814;"
                                       Foreground="#FF5B5B" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock x:Name="CriticalMetricText" Foreground="#FF5B5B" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Text="Критичных остатков" Style="{StaticResource MetricLabelStyle}" />
                            <TextBlock Text="Требуют внимания" Style="{StaticResource MetricHintStyle}" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" FontFamily="Segoe Fluent Icons" Text="&#xE76C;" FontSize="14" Foreground="#A1ABC1" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Width="252"
                        Margin="0,0,14,14"
                        Style="{StaticResource MetricCardStyle}"
                        Cursor="Hand"
                        Tag="transfers"
                        MouseLeftButtonUp="HandleMetricCardClick">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource MetricIconBoxStyle}" Background="#FFF7EC">
                            <TextBlock Style="{StaticResource MetricIconTextStyle}"
                                       Text="&#xE8AB;"
                                       FontSize="16"
                                       Foreground="#FF9F1A" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock x:Name="TransfersMetricText" Foreground="#FF9F1A" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Text="Перемещений в работе" Style="{StaticResource MetricLabelStyle}" />
                            <TextBlock Text="Идет выполнение" Style="{StaticResource MetricHintStyle}" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" FontFamily="Segoe Fluent Icons" Text="&#xE76C;" FontSize="14" Foreground="#A1ABC1" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Width="252"
                        Margin="0,0,14,14"
                        Style="{StaticResource MetricCardStyle}"
                        Cursor="Hand"
                        Tag="reservations"
                        MouseLeftButtonUp="HandleMetricCardClick">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource MetricIconBoxStyle}" Background="#EEF2FF">
                            <TextBlock Style="{StaticResource MetricIconTextStyle}"
                                       Text="&#xE7C3;"
                                       Foreground="#4F5BFF" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock x:Name="ReservationsMetricText" Foreground="#4F5BFF" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Text="Резервов к сборке" Style="{StaticResource MetricLabelStyle}" />
                            <TextBlock Text="Ожидают отгрузки" Style="{StaticResource MetricHintStyle}" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" FontFamily="Segoe Fluent Icons" Text="&#xE76C;" FontSize="14" Foreground="#A1ABC1" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Width="300"
                        Margin="0,0,0,14"
                        Style="{StaticResource MetricCardStyle}"
                        Cursor="Hand"
                        Tag="inventory"
                        MouseLeftButtonUp="HandleMetricCardClick">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource MetricIconBoxStyle}" Background="#F0FAF4">
                            <TextBlock Style="{StaticResource MetricIconTextStyle}"
                                       Text="&#xE73E;"
                                       Foreground="#26A85B" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock x:Name="InventoryMetricText" Foreground="#26A85B" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Text="Расхождений инвентаризации" Style="{StaticResource MetricLabelStyle}" />
                            <TextBlock Text="Требуют проверки" Style="{StaticResource MetricHintStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </WrapPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,18">
                <Button x:Name="StockTabButton" Style="{StaticResource SectionTabStyle}" Click="HandleSectionTabClick" Tag="stock" Content="Остатки" />
                <Button x:Name="TransfersTabButton" Style="{StaticResource SectionTabStyle}" Click="HandleSectionTabClick" Tag="transfers" Content="Перемещения" />
                <Button x:Name="ReservationsTabButton" Style="{StaticResource SectionTabStyle}" Click="HandleSectionTabClick" Tag="reservations" Content="Резервы" />
                <Button x:Name="CellStorageTabButton" Style="{StaticResource SectionTabStyle}" Click="HandleSectionTabClick" Tag="cellstorage" Content="Ячейки и отбор" />
                <Button x:Name="ExpenseInvoicesTabButton" Style="{StaticResource SectionTabStyle}" Click="HandleSectionTabClick" Tag="expenseinvoices" Content="Расходные накладные" />
                <Button x:Name="InventoryTabButton" Style="{StaticResource SectionTabStyle}" Click="HandleSectionTabClick" Tag="inventory" Content="Инвентаризация" />
                <Button x:Name="WriteOffsTabButton" Style="{StaticResource SectionTabStyle}" Click="HandleSectionTabClick" Tag="writeoffs" Content="Списания" />
            </StackPanel>

            <Grid Grid.Row="3">
                <Grid x:Name="StockTabContent">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource TableFilterSearchContainerStyle}"
                                Margin="0,0,12,0"
                                CornerRadius="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="StockSearchBox"
                                         Style="{StaticResource TableFilterSearchTextBoxStyle}"
                                         TextChanged="HandleStockSearchTextChanged" />
                                <TextBlock x:Name="StockSearchPlaceholder"
                                           Text="Поиск по товару, коду или штрихкоду..."
                                           Style="{StaticResource TableFilterSearchPlaceholderStyle}" />
                                <TextBlock Grid.Column="1" Style="{StaticResource TableFilterSearchIconStyle}" />
                            </Grid>
                        </Border>

                        <ComboBox x:Name="WarehouseFilterCombo"
                                  Grid.Column="1"
                                  Margin="0,0,10,0"
                                  Style="{StaticResource FilterComboStyle}"
                                  SelectionChanged="HandleFilterChanged" />
                        <ComboBox x:Name="TypeFilterCombo"
                                  Grid.Column="2"
                                  Margin="0,0,10,0"
                                  Style="{StaticResource FilterComboStyle}"
                                  SelectionChanged="HandleFilterChanged" />
                        <ComboBox x:Name="StatusFilterCombo"
                                  Grid.Column="3"
                                  Margin="0,0,14,0"
                                  Style="{StaticResource FilterComboStyle}"
                                  SelectionChanged="HandleFilterChanged" />

                        <CheckBox x:Name="ProblemsOnlyCheckBox"
                                  Grid.Column="4"
                                  Margin="0,0,14,0"
                                  VerticalAlignment="Center"
                                  Content="Только проблемные"
                                  Style="{StaticResource ProblemsOnlyStyle}"
                                  Checked="HandleFilterChanged"
                                  Unchecked="HandleFilterChanged" />

                        <Button x:Name="FiltersButton"
                                Grid.Column="5"
                                Width="96"
                                Style="{StaticResource TableFilterActionButtonStyle}"
                                Click="HandleFiltersButtonClick">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock FontFamily="Segoe Fluent Icons"
                                           Text="&#xE71C;"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Фильтры" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="TableSettingsButton"
                                Grid.Column="6"
                                Width="42"
                                Style="{StaticResource TableFilterActionButtonStyle}"
                                AutomationProperties.Name="Настройки таблицы склада"
                                Click="HandleFiltersButtonClick">
                            <TextBlock FontFamily="Segoe Fluent Icons"
                                       Text="&#xE713;"
                                       FontSize="15"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Button>
                    </Grid>

                    <Border x:Name="BulkActionsPanel"
                            Grid.Row="1"
                            Margin="0,0,0,16"
                            Style="{StaticResource TableBulkBarStyle}"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="BulkSelectedCountText"
                                           Style="{StaticResource TableBulkTextStyle}" />
                                <Button Margin="12,0,0,0"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="0"
                                        Foreground="#4F5BFF"
                                        FontSize="13"
                                        Cursor="Hand"
                                        Click="HandleBulkClearClick"
                                        Content="Очистить" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="22,0,0,0" VerticalAlignment="Center">
                                <Button Margin="0,0,8,0" Style="{StaticResource TableBulkActionButtonStyle}" Click="HandleBulkTransferClick" Content="Переместить" />
                                <Button Margin="0,0,8,0" Style="{StaticResource TableBulkActionButtonStyle}" Click="HandleBulkReserveClick" Content="Зарезервировать" />
                                <Button Margin="0,0,8,0" Style="{StaticResource TableBulkActionButtonStyle}" Click="HandleBulkShipClick" Content="Отгрузить" />
                                <Button Margin="0,0,8,0" Style="{StaticResource TableBulkActionButtonStyle}" Click="HandleBulkWriteOffClick" Content="Списать" />
                                <Button Margin="0,0,8,0" Style="{StaticResource TableBulkActionButtonStyle}" Click="HandleBulkInventoryClick" Content="Создать инвентаризацию" />
                                <Button Width="42" Style="{StaticResource TableBulkActionButtonStyle}" AutomationProperties.Name="Дополнительные действия склада" FontFamily="Segoe Fluent Icons" Click="HandleBulkMoreClick" Content="&#xE712;" />
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Style="{StaticResource TableBulkCloseButtonStyle}"
                                    AutomationProperties.Name="Закрыть панель выбранных позиций"
                                    Click="HandleBulkCloseClick"
                                    Content="×" />
                        </Grid>
                    </Border>

                    <Grid x:Name="StockLayoutGrid" Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="360" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="StockTableCard"
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,20,0"
                                Padding="0"
                                Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="58" />
                                </Grid.RowDefinitions>

                                <DataGrid x:Name="StockDataGrid"
                                          Style="{StaticResource StockGridStyle}"
                                          ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                          RowStyle="{StaticResource GridRowStyle}"
                                          SelectionChanged="HandleStockSelectionChanged"
                                          ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Width="42">
                                            <DataGridTemplateColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <Border Width="16" Height="16" CornerRadius="4" BorderBrush="#DCE3F1" BorderThickness="1" Background="#FFFFFF" HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.HeaderTemplate>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              Click="HandleStockRowCheckBoxClick" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="Код" Binding="{Binding Code}" Width="118" />

                                        <DataGridTemplateColumn Header="Товар" Width="260">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Item}"
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               MaxHeight="38" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="Склад" Binding="{Binding Warehouse}" Width="125" />

                                        <DataGridTemplateColumn Width="210">
                                            <DataGridTemplateColumn.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Свободно" />
                                                    <TextBlock FontFamily="Segoe Fluent Icons"
                                                               Text="&#xE946;"
                                                               FontSize="10"
                                                               Foreground="#98A3BC"
                                                               Margin="6,0,0,0"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </DataGridTemplateColumn.Header>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding FreeDisplay}" FontSize="14" Foreground="#1B2440" />
                                                        <Border Margin="0,6,0,0" Width="92" Height="6" Background="#EDF1FB" CornerRadius="3" HorizontalAlignment="Left">
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                                <Border Width="{Binding FreeBarWidth}" Height="6" Background="#26A85B" CornerRadius="3" />
                                                                <Border Width="{Binding ReservedBarWidth}" Height="6" Background="#FF9F1A" CornerRadius="3" Margin="2,0,0,0" />
                                                                <Border Width="{Binding InTransitBarWidth}" Height="6" Background="#4F5BFF" CornerRadius="3" Margin="2,0,0,0" />
                                                            </StackPanel>
                                                        </Border>
                                                        <TextBlock Text="{Binding BalanceText}" Margin="0,6,0,0" FontSize="12" Foreground="#73809C" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="Резерв" Binding="{Binding ReservedDisplay}" Width="74" />
                                        <DataGridTextColumn Header="В пути" Binding="{Binding InTransitDisplay}" Width="74" />
                                        <DataGridTextColumn Header="Мин. остаток" Binding="{Binding MinimumDisplay}" Width="96" />

                                        <DataGridTemplateColumn Header="Статус" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Background="{Binding StatusBackground}"
                                                            Padding="10,5"
                                                            CornerRadius="10"
                                                            HorizontalAlignment="Left">
                                                        <TextBlock Text="{Binding Status}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{Binding StatusForeground}" />
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="Обновлено" Binding="{Binding UpdatedDisplay}" Width="120" />

                                        <DataGridTemplateColumn Header="" Width="42">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource TableRowActionButtonStyle}"
                                                            AutomationProperties.Name="Действия позиции склада"
                                                            Tag="{Binding}"
                                                            Click="HandleStockRowActionsClick"
                                                            Content="&#xE712;" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Grid Grid.Row="1" Style="{StaticResource TableFooterGridStyle}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock x:Name="ShownCountText"
                                                   Style="{StaticResource TableFooterTextStyle}" />
                                        <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="●" FontSize="10" Foreground="#26A85B" VerticalAlignment="Center" />
                                            <TextBlock Text="Свободно" Margin="7,0,16,0" FontSize="14" Foreground="#5B6A89" VerticalAlignment="Center" />
                                            <TextBlock Text="●" FontSize="10" Foreground="#FF9F1A" VerticalAlignment="Center" />
                                            <TextBlock Text="В резерве" Margin="7,0,16,0" FontSize="14" Foreground="#5B6A89" VerticalAlignment="Center" />
                                            <TextBlock Text="●" FontSize="10" Foreground="#4F5BFF" VerticalAlignment="Center" />
                                            <TextBlock Text="В пути" Margin="7,0,0,0" FontSize="14" Foreground="#5B6A89" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Style="{StaticResource TablePagerPanelStyle}">
                                        <StackPanel x:Name="PagerPanel" Style="{StaticResource TablePagerPanelStyle}" />
                                        <ComboBox x:Name="RowsPerPageComboBox"
                                                  Width="82"
                                                  Style="{StaticResource TablePageSizeComboBoxStyle}"
                                                  Margin="14,0,0,0"
                                                  SelectedIndex="0">
                                            <ComboBoxItem Content="8 / стр." />
                                            <ComboBoxItem Content="20 / стр." />
                                            <ComboBoxItem Content="50 / стр." />
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border x:Name="DetailsCard"
                                Grid.Row="0"
                                Grid.Column="1"
                                Padding="20"
                                Style="{StaticResource CardStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="72"
                                                Height="60"
                                                Margin="0,0,14,0"
                                                Background="#F1F4FA"
                                                CornerRadius="12">
                                            <Grid>
                                                <Rectangle Width="44"
                                                           Height="28"
                                                           Fill="#101827"
                                                           RadiusX="3"
                                                           RadiusY="3"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           RenderTransformOrigin="0.5,0.5">
                                                    <Rectangle.RenderTransform>
                                                        <RotateTransform Angle="-18" />
                                                    </Rectangle.RenderTransform>
                                                </Rectangle>
                                            </Grid>
                                        </Border>

                                        <TextBlock x:Name="SelectedItemTitleText"
                                                   Grid.Column="1"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="#1B2440"
                                                   TextWrapping="Wrap" />
                                        <Border x:Name="SelectedStatusBadge"
                                                Grid.Column="2"
                                                Margin="12,0,0,0"
                                                Padding="10,5"
                                                CornerRadius="10">
                                            <TextBlock x:Name="SelectedStatusText"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                        <Button x:Name="DetailsActionsButton"
                                                Grid.Column="3"
                                                Margin="12,0,0,0"
                                                Style="{StaticResource TableRowActionButtonStyle}"
                                                AutomationProperties.Name="Действия выбранной позиции склада"
                                                Click="HandleDetailsActionsClick"
                                                Content="&#xE712;" />
                                    </Grid>

                                    <TextBlock x:Name="SelectedWarehouseText"
                                               Margin="0,8,0,0"
                                               FontSize="14"
                                               Foreground="#6E7B98" />

                                    <Grid Margin="0,18,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="Код" FontSize="13" Foreground="#7A86A0" />
                                            <TextBlock x:Name="SelectedCodeText" Margin="0,4,0,0" FontSize="14" Foreground="#1B2440" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                            <TextBlock Text="Номенклатура" FontSize="13" Foreground="#7A86A0" />
                                            <TextBlock x:Name="SelectedNameText" Margin="0,4,0,0" FontSize="14" Foreground="#1B2440" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="Склад" FontSize="13" Foreground="#7A86A0" />
                                            <TextBlock x:Name="SelectedStockWarehouseText" Margin="0,4,0,0" FontSize="14" Foreground="#1B2440" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                            <TextBlock Text="Ед. изм." FontSize="13" Foreground="#7A86A0" />
                                            <TextBlock x:Name="SelectedUnitText" Margin="0,4,0,0" FontSize="14" Foreground="#1B2440" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Margin="0,16,0,0">
                                        <TextBlock Text="Штрихкод" FontSize="13" Foreground="#7A86A0" />
                                        <TextBlock x:Name="SelectedBarcodeText" Margin="0,4,0,0" FontSize="14" Foreground="#1B2440" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                        <TextBlock Text="Остатки" FontSize="14" FontWeight="SemiBold" Foreground="#1B2440" />
                                        <TextBlock x:Name="SelectedStockTimestampText"
                                                   Margin="12,1,0,0"
                                                   FontSize="12"
                                                   Foreground="#98A3BC"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>

                                    <primitives:UniformGrid Columns="3" Margin="0,12,0,0">
                                        <Border Background="#F0FAF4" CornerRadius="14" Padding="14" Margin="0,0,10,0">
                                            <StackPanel>
                                                <TextBlock x:Name="FreeQuantityText" FontSize="18" FontWeight="SemiBold" Foreground="#26A85B" />
                                                <TextBlock Text="Свободно" Margin="0,4,0,0" FontSize="13" Foreground="#6E7B98" />
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#FFF8ED" CornerRadius="14" Padding="14" Margin="0,0,10,0">
                                            <StackPanel>
                                                <TextBlock x:Name="ReservedQuantityText" FontSize="18" FontWeight="SemiBold" Foreground="#FF9F1A" />
                                                <TextBlock Text="В резерве" Margin="0,4,0,0" FontSize="13" Foreground="#6E7B98" />
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#EEF2FF" CornerRadius="14" Padding="14">
                                            <StackPanel>
                                                <TextBlock x:Name="TransitQuantityText" FontSize="18" FontWeight="SemiBold" Foreground="#4F5BFF" />
                                                <TextBlock Text="В пути" Margin="0,4,0,0" FontSize="13" Foreground="#6E7B98" />
                                            </StackPanel>
                                        </Border>
                                    </primitives:UniformGrid>

                                    <Grid Margin="0,18,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="Минимальный остаток" FontSize="13" Foreground="#7A86A0" />
                                            <TextBlock x:Name="MinimumStockText" Margin="0,4,0,0" FontSize="16" FontWeight="SemiBold" Foreground="#1B2440" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                            <TextBlock Text="Дефицит" FontSize="13" Foreground="#7A86A0" />
                                            <TextBlock x:Name="DeficitText" Margin="0,4,0,0" FontSize="16" FontWeight="SemiBold" Foreground="#FF5B5B" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="Последние движения" Margin="0,24,0,0" FontSize="14" FontWeight="SemiBold" Foreground="#1B2440" />
                                    <ItemsControl x:Name="MovementsItemsControl" Margin="0,10,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Caption}" FontSize="13" Foreground="#4D5B77" TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding Subtitle}" Margin="0,2,0,0" FontSize="12" Foreground="#98A3BC" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Delta}"
                                                               Margin="12,0,0,0"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding DeltaBrush}"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="Связанные документы" Margin="0,22,0,0" FontSize="14" FontWeight="SemiBold" Foreground="#1B2440" />
                                    <ItemsControl x:Name="DocumentsItemsControl" Margin="0,10,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Margin="0,0,0,10"
                                                        Padding="0"
                                                        Background="Transparent"
                                                        BorderBrush="Transparent"
                                                        BorderThickness="0"
                                                HorizontalContentAlignment="Left"
                                                Cursor="Hand"
                                                Tag="{Binding}"
                                                AutomationProperties.Name="{Binding Caption}"
                                                Click="HandleLinkedDocumentClick">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Caption}" FontSize="13" Foreground="#4F5BFF" TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding Subtitle}" Margin="0,2,0,0" FontSize="12" Foreground="#98A3BC" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="Быстрые действия" Margin="0,22,0,0" FontSize="14" FontWeight="SemiBold" Foreground="#1B2440" />
                                    <primitives:UniformGrid Columns="2" Margin="0,12,0,0">
                                        <Button Margin="0,0,10,10" Style="{StaticResource QuickActionButtonStyle}" Click="HandleEditSelectedStockClick" Content="Изменить" />
                                        <Button Margin="0,0,0,10" Style="{StaticResource QuickActionButtonStyle}" Click="HandlePrintLabelsClick" Content="Печать этикетки" />
                                        <Button Margin="0,0,10,10" Style="{StaticResource QuickActionButtonStyle}" Click="HandleCreateTransferClick" Content="Переместить" />
                                        <Button Margin="0,0,0,10" Style="{StaticResource QuickActionButtonStyle}" Click="HandleOpenReservationsClick" Content="Зарезервировать" />
                                        <Button Margin="0,0,10,10" Style="{StaticResource QuickActionButtonStyle}" Click="HandleCreateWriteOffClick" Content="Списать" />
                                        <Button Margin="0,0,0,10" Style="{StaticResource QuickActionButtonStyle}" Click="HandlePurchaseSelectedClick" Content="Создать закупку" />
                                        <Button Margin="0,0,10,0" Style="{StaticResource QuickActionButtonStyle}" Click="HandleCreateInventoryClick" Content="Инвентаризация" />
                                        <Button Margin="0,0,0,0" Style="{StaticResource QuickActionButtonStyle}" Click="HandleUpdatePriceClick" Content="Установить цену" />
                                    </primitives:UniformGrid>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <Grid x:Name="CellStorageTabContent" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <WrapPanel Grid.Row="0" Margin="0,0,0,18">
                        <Border Width="260" Margin="0,0,14,14" Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock x:Name="CellTodayMetricText" Foreground="#4F5BFF" Style="{StaticResource MetricValueStyle}" />
                                <TextBlock Text="К отгрузке сегодня" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock Text="Активные отгрузки на дату" Style="{StaticResource MetricHintStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Width="260" Margin="0,0,14,14" Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock x:Name="CellReadyMetricText" Foreground="#26A85B" Style="{StaticResource MetricValueStyle}" />
                                <TextBlock Text="Готово к сборке" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock Text="Товара хватает и ячейки есть" Style="{StaticResource MetricHintStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Width="260" Margin="0,0,14,14" Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock x:Name="CellShortMetricText" Foreground="#FF5B5B" Style="{StaticResource MetricValueStyle}" />
                                <TextBlock Text="Не хватает товара" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock Text="Нужна закупка или перемещение" Style="{StaticResource MetricHintStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Width="260" Margin="0,0,0,14" Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock x:Name="CellMissingMetricText" Foreground="#FF9F1A" Style="{StaticResource MetricValueStyle}" />
                                <TextBlock Text="Без точной ячейки" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock Text="Остаток есть, адрес не указан" Style="{StaticResource MetricHintStyle}" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <Grid Grid.Row="1" Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="440" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Margin="0,0,18,0" Padding="0" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="420" />
                                </Grid.RowDefinitions>

                                <StackPanel Margin="22,22,22,14">
                                    <TextBlock Text="Отгрузки на сегодня" FontSize="22" FontWeight="SemiBold" Foreground="#1B2440" />
                                    <TextBlock Text="Очередь кладовщика по активным отгрузкам." Margin="0,6,0,0" FontSize="13.5" Foreground="#6E7B98" TextWrapping="Wrap" />
                                    <TextBox x:Name="CellShipmentSearchBox"
                                             Height="36"
                                             Margin="0,14,0,0"
                                             VerticalContentAlignment="Center"
                                             ToolTip="Поиск по отгрузке, заказу, клиенту, складу или товару"
                                             TextChanged="HandleCellShipmentSearchChanged" />
                                    <CheckBox x:Name="CellOnlyProblemShipmentsCheckBox"
                                              Margin="0,12,0,0"
                                              Style="{StaticResource ProblemsOnlyStyle}"
                                              Checked="HandleCellShipmentFilterChanged"
                                              Unchecked="HandleCellShipmentFilterChanged"
                                              Content="Только с дефицитом или без ячеек" />
                                    <TextBlock x:Name="CellVisibleQueueText"
                                               Margin="0,10,0,0"
                                               FontSize="12.5"
                                               Foreground="#98A3BC" />
                                </StackPanel>

                                <DataGrid x:Name="CellShipmentsDataGrid"
                                          Grid.Row="1"
                                          Style="{StaticResource StockGridStyle}"
                                          ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                          RowStyle="{StaticResource GridRowStyle}"
                                          SelectionChanged="HandleCellShipmentSelectionChanged"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Отгрузка" Binding="{Binding Number}" Width="120" />
                                        <DataGridTextColumn Header="Клиент" Binding="{Binding Customer}" Width="*" />
                                        <DataGridTemplateColumn Header="Готовность" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Background="{Binding StatusBackground}" CornerRadius="10" Padding="10,4" HorizontalAlignment="Left">
                                                        <TextBlock Text="{Binding Readiness}" FontSize="12" FontWeight="SemiBold" Foreground="{Binding StatusForeground}" />
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Padding="0" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="420" />
                                </Grid.RowDefinitions>

                                <StackPanel Margin="22,22,22,14">
                                    <TextBlock x:Name="CellSelectedShipmentTitleText" FontSize="22" FontWeight="SemiBold" Foreground="#1B2440" />
                                    <TextBlock x:Name="CellSelectedShipmentSubtitleText" Margin="0,6,0,0" FontSize="13.5" Foreground="#6E7B98" TextWrapping="Wrap" />
                                    <Button x:Name="CellOpenShipmentButton"
                                            Width="150"
                                            Height="38"
                                            Margin="0,12,0,0"
                                            HorizontalAlignment="Left"
                                            Style="{StaticResource QuickActionButtonStyle}"
                                            Click="HandleOpenSelectedCellShipmentClick"
                                            Content="Открыть отгрузку" />
                                </StackPanel>

                                <DataGrid x:Name="CellPickLinesDataGrid"
                                          Grid.Row="1"
                                          Style="{StaticResource StockGridStyle}"
                                          ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                          RowStyle="{StaticResource GridRowStyle}"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Код" Binding="{Binding Code}" Width="120" />
                                        <DataGridTextColumn Header="Товар" Binding="{Binding Item}" Width="260" />
                                        <DataGridTextColumn Header="Нужно" Binding="{Binding RequiredDisplay}" Width="100" />
                                        <DataGridTextColumn Header="Доступно" Binding="{Binding AvailableDisplay}" Width="110" />
                                        <DataGridTextColumn Header="Не хватает" Binding="{Binding ShortageDisplay}" Width="110" />
                                        <DataGridTextColumn Header="Ячейки" Binding="{Binding CellDisplay}" Width="260" />
                                        <DataGridTemplateColumn Header="Статус" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Background="{Binding StatusBackground}" CornerRadius="10" Padding="10,4" HorizontalAlignment="Left">
                                                        <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold" Foreground="{Binding StatusForeground}" />
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2" Padding="0" Margin="0,0,0,18" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="300" />
                            </Grid.RowDefinitions>

                            <Grid Margin="22,22,22,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Справочник ячеек" FontSize="22" FontWeight="SemiBold" Foreground="#1B2440" />
                                    <TextBlock Text="Постоянные адреса склада. QR подготовлен, но рабочие операции могут заполняться вручную." Margin="0,6,0,0" FontSize="13.5" Foreground="#6E7B98" TextWrapping="Wrap" />
                                </StackPanel>
                                <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right">
                                    <ComboBox x:Name="StorageCellWarehouseFilterCombo"
                                              Width="170"
                                              Margin="0,0,10,0"
                                              Style="{StaticResource FilterComboStyle}"
                                              SelectionChanged="HandleStorageCellFilterChanged" />
                                    <TextBox x:Name="StorageCellSearchBox"
                                             Width="190"
                                             Height="36"
                                             Margin="0,0,10,0"
                                             VerticalContentAlignment="Center"
                                             TextChanged="HandleStorageCellSearchChanged" />
                                    <Button Width="120"
                                            Height="36"
                                            Margin="0,0,8,0"
                                            Style="{StaticResource QuickActionButtonStyle}"
                                            Click="HandleAddStorageCellClick"
                                            Content="Новая" />
                                    <Button Width="120"
                                            Height="36"
                                            Margin="0,0,8,0"
                                            Style="{StaticResource QuickActionButtonStyle}"
                                            Click="HandleEditStorageCellClick"
                                            Content="Изменить" />
                                    <Button x:Name="ToggleStorageCellButton"
                                            Width="140"
                                            Height="36"
                                            Margin="0,0,8,0"
                                            Style="{StaticResource QuickActionButtonStyle}"
                                            Click="HandleToggleStorageCellClick"
                                            Content="Закрыть" />
                                    <Button Width="150"
                                            Height="36"
                                            Style="{StaticResource QuickActionButtonStyle}"
                                            Click="HandleEnsureStorageCellsClick"
                                            Content="Шаблон" />
                                </WrapPanel>
                            </Grid>

                            <DataGrid x:Name="StorageCellsDataGrid"
                                      Grid.Row="1"
                                      Style="{StaticResource StockGridStyle}"
                                      ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                      RowStyle="{StaticResource GridRowStyle}"
                                      SelectionChanged="HandleStorageCellSelectionChanged"
                                      MouseDoubleClick="HandleStorageCellDoubleClick"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Ячейка" Binding="{Binding Code}" Width="160" />
                                    <DataGridTextColumn Header="Склад" Binding="{Binding Warehouse}" Width="180" />
                                    <DataGridTextColumn Header="Зона" Binding="{Binding Zone}" Width="130" />
                                    <DataGridTextColumn Header="Тип" Binding="{Binding CellType}" Width="130" />
                                    <DataGridTextColumn Header="Лимит" Binding="{Binding CapacityDisplay}" Width="100" />
                                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120" />
                                    <DataGridTextColumn Header="QR" Binding="{Binding QrState}" Width="130" />
                                    <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3" Padding="0" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="360" />
                            </Grid.RowDefinitions>

                            <StackPanel Margin="22,22,22,14">
                                <TextBlock Text="Остатки по ячейкам" FontSize="22" FontWeight="SemiBold" Foreground="#1B2440" />
                                <TextBlock Text="Адреса считаются из приемок, перемещений, инвентаризаций и списаний." Margin="0,6,0,0" FontSize="13.5" Foreground="#6E7B98" TextWrapping="Wrap" />
                            </StackPanel>

                            <DataGrid x:Name="CellBalancesDataGrid"
                                      Grid.Row="1"
                                      Style="{StaticResource StockGridStyle}"
                                      ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                      RowStyle="{StaticResource GridRowStyle}"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Ячейка" Binding="{Binding Cell}" Width="150" />
                                    <DataGridTextColumn Header="Склад" Binding="{Binding Warehouse}" Width="160" />
                                    <DataGridTextColumn Header="Код" Binding="{Binding Code}" Width="120" />
                                    <DataGridTextColumn Header="Товар" Binding="{Binding Item}" Width="*" />
                                    <DataGridTextColumn Header="Кол-во" Binding="{Binding QuantityDisplay}" Width="120" />
                                    <DataGridTextColumn Header="Источник" Binding="{Binding Source}" Width="240" />
                                    <DataGridTemplateColumn Header="Адрес" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding StatusBackground}" CornerRadius="10" Padding="10,4" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold" Foreground="{Binding StatusForeground}" />
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>

                <Grid x:Name="DocumentsTabContent" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Height="42"
                                Margin="0,0,12,0"
                                Background="#FFFFFF"
                                BorderBrush="#E4EAF5"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16,0,14,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="DocumentsSearchBox"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="14"
                                         Foreground="#1B2440"
                                         VerticalContentAlignment="Center"
                                         TextChanged="HandleDocumentsSearchTextChanged" />
                                <TextBlock x:Name="DocumentsSearchPlaceholder"
                                           Text="Поиск по документам и складам..."
                                           FontSize="14"
                                           Foreground="#98A3BC"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False" />
                                <TextBlock Grid.Column="1"
                                           FontFamily="Segoe Fluent Icons"
                                           Text="&#xE721;"
                                           FontSize="15"
                                           Foreground="#73809C"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Button x:Name="DocumentsPrimaryButton"
                                Grid.Column="1"
                                Width="184"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="HandleDocumentsPrimaryActionClick" />
                    </Grid>

                    <Border Grid.Row="1" Padding="0" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="58" />
                            </Grid.RowDefinitions>

                            <StackPanel Margin="22,22,22,16">
                                <TextBlock x:Name="DocumentsSectionTitleText"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           Foreground="#1B2440" />
                                <TextBlock x:Name="DocumentsSectionSubtitleText"
                                           Margin="0,6,0,0"
                                           FontSize="14"
                                           Foreground="#6E7B98"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <DataGrid x:Name="DocumentsDataGrid"
                                      Grid.Row="1"
                                      Style="{StaticResource StockGridStyle}"
                                      ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                      RowStyle="{StaticResource GridRowStyle}"
                                      MouseDoubleClick="HandleDocumentsGridDoubleClick"
                                      ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="№ документа" Binding="{Binding Number}" Width="180" />
                                    <DataGridTextColumn Header="Дата" Binding="{Binding DateText}" Width="120" />
                                    <DataGridTextColumn Header="Маршрут" Binding="{Binding Route}" Width="320" />
                                    <DataGridTemplateColumn Header="Статус" Width="146">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding StatusBackground}" CornerRadius="10" Padding="10,4" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold" Foreground="{Binding StatusForeground}" />
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Основание" Binding="{Binding RelatedDocument}" Width="220" />
                                    <DataGridTextColumn Header="Позиций" Binding="{Binding Positions}" Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <Grid Grid.Row="2" Style="{StaticResource TableFooterGridStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="DocumentsShownCountText"
                                           Style="{StaticResource TableFooterTextStyle}" />
                                <StackPanel x:Name="DocumentsPagerPanel"
                                            Grid.Column="1"
                                            Style="{StaticResource TablePagerPanelStyle}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>

