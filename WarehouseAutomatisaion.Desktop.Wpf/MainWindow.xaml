<Window x:Class="WarehouseAutomatisaion.Desktop.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MajorWarehause"
        Width="1440"
        Height="920"
        MinWidth="1240"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="#F7F9FF">
    <Window.Resources>
        <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#596683" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F6F8FF" />
                    <Setter Property="BorderBrush" Value="#D9E1FF" />
                    <Setter Property="Foreground" Value="#2F3F74" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#EEF2FF" />
                    <Setter Property="BorderBrush" Value="#C7D1FF" />
                    <Setter Property="Foreground" Value="#22305B" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#A9B3C7" />
                    <Setter Property="Cursor" Value="Arrow" />
                    <Setter Property="Opacity" Value="0.62" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#1F2A44" />
            <Setter Property="BorderBrush" Value="#E3EAF6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12,12,0,0"
                                Padding="0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="214" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border x:Name="SidebarChrome"
                Grid.Column="0"
                Background="#FFFFFF"
                BorderBrush="#E8EDF7"
                BorderThickness="0,0,1,0">
            <Grid x:Name="SidebarRoot" Margin="16,18,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel x:Name="SidebarHeaderPanel" Grid.Row="0" Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="28"
                                Height="28"
                                CornerRadius="9"
                                Background="#4F5BFF">
                            <Grid>
                                <Rectangle Width="12"
                                           Height="12"
                                           RadiusX="3"
                                           RadiusY="3"
                                           Fill="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <TextBlock x:Name="ApplicationNameText"
                                   Text="MajorWarehause"
                                   Margin="12,0,0,0"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   Foreground="#1B2440"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="SidebarNavigationTitleText"
                               Text="Разделы"
                               Margin="0,0,0,12"
                               FontSize="14"
                               Foreground="#7A86A5" />

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <Button x:Name="NavDashboardButton"
                                    Tag="dashboard"
                                    AutomationProperties.Name="Главная"
                                    Style="{StaticResource SidebarNavButtonStyle}"
                                    Click="HandleNavButtonClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE80F;" FontSize="15" VerticalAlignment="Center" />
                                    <TextBlock Text="Главная" Margin="12,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="NavSalesButton"
                                    Tag="sales"
                                    AutomationProperties.Name="Заказы"
                                    Style="{StaticResource SidebarNavButtonStyle}"
                                    Click="HandleNavButtonClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE14C;" FontSize="15" VerticalAlignment="Center" />
                                    <TextBlock Text="Заказы" Margin="12,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="NavCustomersButton"
                                    Tag="customers"
                                    AutomationProperties.Name="Клиенты"
                                    Style="{StaticResource SidebarNavButtonStyle}"
                                    Click="HandleNavButtonClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE716;" FontSize="15" VerticalAlignment="Center" />
                                    <TextBlock Text="Клиенты" Margin="12,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="NavShipmentsButton"
                                    Tag="shipments"
                                    AutomationProperties.Name="Отгрузки"
                                    Style="{StaticResource SidebarNavButtonStyle}"
                                    Click="HandleNavButtonClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xEC47;" FontSize="15" VerticalAlignment="Center" />
                                    <TextBlock Text="Отгрузки" Margin="12,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="NavPurchasingButton"
                                    Tag="purchasing"
                                    AutomationProperties.Name="Закупки"
                                    Style="{StaticResource SidebarNavButtonStyle}"
                                    Click="HandleNavButtonClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE719;" FontSize="15" VerticalAlignment="Center" />
                                    <TextBlock Text="Закупки" Margin="12,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="NavWarehouseButton"
                                    Tag="warehouse"
                                    AutomationProperties.Name="Склад"
                                    Style="{StaticResource SidebarNavButtonStyle}"
                                    Click="HandleNavButtonClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE7F8;" FontSize="15" VerticalAlignment="Center" />
                                    <TextBlock Text="Склад" Margin="12,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="NavCatalogButton"
                                    Tag="catalog"
                                    AutomationProperties.Name="Товары"
                                    Style="{StaticResource SidebarNavButtonStyle}"
                                    Click="HandleNavButtonClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xEECA;" FontSize="15" VerticalAlignment="Center" />
                                    <TextBlock Text="Товары" Margin="12,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="NavAuditButton"
                                    Tag="audit"
                                    AutomationProperties.Name="Отчеты"
                                    Style="{StaticResource SidebarNavButtonStyle}"
                                    Click="HandleNavButtonClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE9D2;" FontSize="15" VerticalAlignment="Center" />
                                    <TextBlock Text="Отчеты" Margin="12,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="NavSettingsButton"
                                    Tag="settings"
                                    AutomationProperties.Name="Настройки"
                                    Style="{StaticResource SidebarNavButtonStyle}"
                                    Click="HandleNavButtonClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE713;" FontSize="15" VerticalAlignment="Center" />
                                    <TextBlock Text="Настройки" Margin="12,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <StackPanel x:Name="SidebarFooterPanel" Grid.Row="2">
                    <Border x:Name="UserProfileCard"
                            Background="#F7F9FF"
                            BorderBrush="#E6ECF8"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14"
                            Margin="0,18,0,0"
                            Cursor="Hand"
                            MouseLeftButtonUp="HandleUserProfileCardClick"
                            AutomationProperties.Name="Профиль пользователя">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="26" Height="26" CornerRadius="13" Background="#EEF2FF" VerticalAlignment="Top">
                                <TextBlock x:Name="UserAvatarText"
                                           Text="MW"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#4F5BFF" />
                            </Border>
                            <StackPanel x:Name="UserProfileTextPanel" Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock x:Name="UserDisplayNameText"
                                           Text="MajorWarehause"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#24314F" />
                                <TextBlock x:Name="UserRoleText"
                                           Text="Администратор"
                                           Margin="0,3,0,0"
                                           FontSize="11"
                                           Foreground="#7D88A3" />
                            </StackPanel>
                            <TextBlock x:Name="UserProfileChevronText"
                                       Grid.Column="2"
                                       FontFamily="Segoe Fluent Icons"
                                       Text="&#xE70D;"
                                       FontSize="10"
                                       Foreground="#7D88A3"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border x:Name="DatabaseStatusBadge"
                            Background="#FFF4E3"
                            BorderBrush="#FFD9A3"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14"
                            Margin="0,12,0,0"
                            Visibility="Collapsed"
                            AutomationProperties.Name="Источник данных">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="DatabaseStatusIconText"
                                       FontFamily="Segoe Fluent Icons"
                                       Text="&#xE783;"
                                       FontSize="15"
                                       Foreground="#B76600"
                                       VerticalAlignment="Top" />
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock x:Name="DatabaseStatusTitleText"
                                           Text="Локальные данные"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#24314F" />
                                <TextBlock x:Name="DatabaseStatusText"
                                           Margin="0,4,0,0"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Foreground="#6E7A96" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border x:Name="UpdatePanelCard"
                            Background="#FFFFFF"
                            BorderBrush="#E6ECF8"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14"
                            Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Обновление"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#24314F" />
                            <TextBlock x:Name="ApplicationVersionText"
                                       Margin="0,6,0,0"
                                       FontSize="11"
                                       Foreground="#6E7A96" />
                            <TextBlock x:Name="ApplicationUpdateStatusText"
                                       Margin="0,4,0,0"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Foreground="#6E7A96" />
                            <Button x:Name="UpdateApplicationButton"
                                    Margin="0,12,0,0"
                                    Height="36"
                                    Padding="12,0"
                                    BorderThickness="0"
                                    Background="#1F2A44"
                                    Foreground="White"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Click="HandleUpdateApplicationClick"
                                    Content="Проверить обновления" />
                        </StackPanel>
                    </Border>

                    <Button x:Name="SidebarCollapseButton"
                            Margin="0,14,0,0"
                            Height="36"
                            Padding="10,0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Foreground="#6D7892"
                            HorizontalContentAlignment="Left"
                            Cursor="Hand"
                            AutomationProperties.Name="Свернуть меню"
                            Click="HandleSidebarCollapseClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="SidebarCollapseIconText"
                                       FontFamily="Segoe Fluent Icons"
                                       Text="&#xE76B;"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="SidebarCollapseText"
                                       Text="Свернуть меню"
                                       Margin="10,0,0,0"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="0" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="18,14,18,18">
                <TabControl x:Name="WorkspaceTabs"
                            SelectionChanged="HandleWorkspaceTabsSelectionChanged"
                            Background="Transparent"
                            BorderBrush="Transparent" />
            </Grid>

            <Grid Grid.Row="1" Visibility="Collapsed">
                <TextBlock x:Name="CurrentSectionTitleText" />
                <TextBlock x:Name="CurrentSectionSubtitleText" />
            </Grid>
        </Grid>
    </Grid>
</Window>
