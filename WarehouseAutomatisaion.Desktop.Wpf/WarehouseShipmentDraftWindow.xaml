<Window x:Class="WarehouseAutomatisaion.Desktop.Wpf.WarehouseShipmentDraftWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="880"
        Height="640"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#F7F9FD"
        Title="Подготовка отгрузки">
    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource DialogFieldLabelStyle}" />
        <Style x:Key="InputStyle" TargetType="Control" BasedOn="{StaticResource DialogInputStyle}" />
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogPrimaryButtonStyle}" />
        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogSecondaryButtonStyle}" />
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock x:Name="HeaderTitleText"
                       Text="Подготовка отгрузки"
                       FontSize="25"
                       FontWeight="SemiBold"
                       Foreground="#17213A" />
            <TextBlock x:Name="HeaderSubtitleText"
                       Text="Выберите клиента и уточните количество по складским позициям."
                       Margin="0,6,0,0"
                       FontSize="13"
                       Foreground="#6E7B98" />
        </StackPanel>

        <Border Grid.Row="1"
                Style="{StaticResource DialogCardStyle}"
                Padding="16"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Клиент" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="CustomerComboBox"
                              Style="{StaticResource InputStyle}"
                              DisplayMemberPath="Label" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Склад" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="WarehouseTextBox"
                             Style="{StaticResource InputStyle}"
                             IsReadOnly="True"
                             Background="#F4F7FC"
                             BorderBrush="#DDE5F4" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource DialogCardStyle}"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Margin="16,14,16,10">
                    <TextBlock Text="Позиции отгрузки"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="#17213A" />
                    <TextBlock x:Name="TotalText"
                               HorizontalAlignment="Right"
                               FontSize="13"
                               Foreground="#6E7B98"
                               VerticalAlignment="Center" />
                </Grid>

                <DataGrid x:Name="LinesGrid"
                          Grid.Row="1"
                          Style="{StaticResource DialogDataGridStyle}"
                          AlternatingRowBackground="#F8FAFF"
                          RowHeight="44"
                          CellEditEnding="HandleCellEditEnding">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Код" Binding="{Binding Code}" Width="120" IsReadOnly="True" />
                        <DataGridTextColumn Header="Товар" Binding="{Binding Name}" Width="2*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Склад" Binding="{Binding Warehouse}" Width="130" IsReadOnly="True" />
                        <DataGridTextColumn Header="Доступно" Binding="{Binding AvailableDisplay}" Width="95" IsReadOnly="True" />
                        <DataGridTextColumn Header="К отгрузке" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="105" />
                        <DataGridTextColumn Header="Ед." Binding="{Binding Unit}" Width="65" IsReadOnly="True" />
                        <DataGridTextColumn Header="Цена" Binding="{Binding PriceDisplay}" Width="105" IsReadOnly="True" />
                        <DataGridTextColumn Header="Сумма" Binding="{Binding AmountDisplay}" Width="120" IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Grid.Row="2"
                           Margin="16,10,16,14"
                           Text="Количество должно быть больше нуля и не больше свободного остатка."
                           Foreground="#6E7B98"
                           FontSize="12" />
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="0,18,0,0">
            <TextBlock x:Name="ValidationText"
                       Foreground="#D92D20"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="0,0,10,0"
                        Click="HandleCancelClick" />
                <Button x:Name="SaveButton"
                        Content="Создать отгрузку"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="HandleSaveClick" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
