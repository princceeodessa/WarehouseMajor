<UserControl x:Class="WarehouseAutomatisaion.Desktop.Wpf.ProductsWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#F7F9FD">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PageBrush" Color="#F7F9FD" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="LineBrush" Color="#E7ECF7" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#4F5BFF" />
        <SolidColorBrush x:Key="TextBrush" Color="#17213A" />
        <SolidColorBrush x:Key="MutedBrush" Color="#7A86A5" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DDE5F4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#34415F" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style x:Key="MiniActionButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="FilterComboStyle" TargetType="ComboBox" BasedOn="{StaticResource TableFilterComboBoxStyle}">
            <Setter Property="MinWidth" Value="116" />
        </Style>

        <Style x:Key="ModuleTabStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="Foreground" Value="#6E7B98" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="0,0,0,13" />
            <Setter Property="Margin" Value="0,0,34,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProductGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserResizeColumns" Value="False" />
            <Setter Property="CanUserSortColumns" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF2FA" />
            <Setter Property="VerticalGridLinesBrush" Value="#EEF2FA" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="RowHeight" Value="58" />
            <Setter Property="ColumnHeaderHeight" Value="44" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="IsReadOnly" Value="False" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="EnableRowVirtualization" Value="True" />
            <Setter Property="EnableColumnVirtualization" Value="True" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        </Style>

        <Style x:Key="GridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#EEF2FA" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="#7B86A0" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,0,10,0" />
        </Style>

        <Style x:Key="GridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#EEF2FA" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="#1B2440" />
            <Setter Property="FontSize" Value="12.5" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FAFBFF" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#F2F5FF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GridCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProblemsOnlyStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#4D5A78" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="SwitchTrack"
                                    Width="34"
                                    Height="20"
                                    CornerRadius="10"
                                    Background="#D8DEEC"
                                    Margin="0,0,9,0">
                                <Ellipse x:Name="SwitchThumb"
                                         Width="14"
                                         Height="14"
                                         Fill="#FFFFFF"
                                         HorizontalAlignment="Left"
                                         Margin="3,3,0,3" />
                            </Border>
                            <ContentPresenter VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#4F5BFF" />
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="0,3,3,3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBrush}" Margin="28,24,28,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="360" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Style="{StaticResource TopHeaderGridStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Style="{StaticResource TopHeaderTextPanelStyle}">
                    <TextBlock Text="Товары"
                               Style="{StaticResource TopHeaderTitleStyle}" />
                    <TextBlock Text="Каталог товаров, качество данных и доступность на складах."
                               Style="{StaticResource TopHeaderSubtitleStyle}" />
                </StackPanel>

                <WrapPanel x:Name="HeaderActionsPanel" Grid.Column="1" Style="{StaticResource TopHeaderActionsWrapPanelStyle}">
                    <Border Width="330"
                            Style="{StaticResource TopSearchContainerStyle}"
                            Margin="0,0,10,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="HeaderSearchBox"
                                     Grid.Column="0"
                                     Style="{StaticResource TopSearchTextBoxStyle}"
                                     TextChanged="HandleSearchTextChanged" />
                            <TextBlock x:Name="HeaderSearchPlaceholderText"
                                       Grid.Column="0"
                                       Text="Поиск по коду, названию или штрихкоду..."
                                       Style="{StaticResource TopSearchPlaceholderStyle}" />
                            <TextBlock Grid.Column="1"
                                       Style="{StaticResource TopSearchIconStyle}" />
                        </Grid>
                    </Border>

                    <Button Style="{StaticResource TopActionButtonStyle}" Margin="0,0,10,0" Click="HandleImportClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE896;" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="Импорт" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource TopActionButtonStyle}" Margin="0,0,10,0" Click="HandleExportClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE74D;" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="Экспорт" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource TopPrimaryActionButtonStyle}" Margin="0,0,10,0" Click="HandleNewProductClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE710;" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="Новый товар" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="ActionsButton"
                            AutomationProperties.Name="Действия товаров"
                            Style="{StaticResource TopActionButtonStyle}"
                            Click="HandleActionsClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Действия" VerticalAlignment="Center" />
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE70D;" Margin="10,0,0,0" FontSize="10" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Grid>

            <UniformGrid x:Name="MetricCardsGrid" Grid.Row="1" Columns="4" Margin="0,0,0,24">
                <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource MetricIconBoxStyle}" Background="#FFF3E8">
                            <TextBlock Style="{StaticResource MetricIconTextStyle}" Text="&#xEA39;" Foreground="#FF8A00" />
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="MissingPriceMetricText" Text="0" Foreground="#FF3045" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Text="Без цены" Style="{StaticResource MetricLabelStyle}" />
                            <TextBlock Text="Товарам не назначена цена" Style="{StaticResource MetricHintStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource MetricIconBoxStyle}" Background="#FFF0F3">
                            <TextBlock Style="{StaticResource MetricIconTextStyle}" Text="&#xE7BA;" Foreground="#FF4D5C" />
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="MissingBarcodeMetricText" Text="0" Foreground="#FF3045" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Text="Без штрихкода" Style="{StaticResource MetricLabelStyle}" />
                            <TextBlock Text="Не заполнен штрихкод" Style="{StaticResource MetricHintStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource MetricIconBoxStyle}" Background="#FFF4E5">
                            <TextBlock Style="{StaticResource MetricIconTextStyle}" Text="&#xE7C1;" Foreground="#FF9500" />
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="LowStockMetricText" Text="0" Foreground="#FF9500" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Text="Низкий остаток" Style="{StaticResource MetricLabelStyle}" />
                            <TextBlock Text="Ниже минимального" Style="{StaticResource MetricHintStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource MetricCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource MetricIconBoxStyle}" Background="#EEF2FF">
                            <TextBlock Style="{StaticResource MetricIconTextStyle}" Text="&#xEECA;" Foreground="#4F5BFF" />
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="MissingSupplierMetricText" Text="0" Foreground="#4F5BFF" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Text="Без поставщика" Style="{StaticResource MetricLabelStyle}" />
                            <TextBlock Text="Не указан поставщик" Style="{StaticResource MetricHintStyle}" />
                        </StackPanel>
                        <Button Grid.Column="2" Content="Все проблемы  →" Style="{StaticResource MiniActionButtonStyle}" BorderThickness="0" Foreground="#4F5BFF" Click="HandleShowProblemsClick" />
                    </Grid>
                </Border>
            </UniformGrid>

            <WrapPanel x:Name="ModuleTabsPanel" Grid.Row="2" Margin="0,0,0,14">
                <Button x:Name="ProductsTabButton" Tag="products" Content="Товары" Style="{StaticResource ModuleTabStyle}" Click="HandleModuleTabClick" />
                <Button x:Name="PriceTypesTabButton" Tag="prices" Content="Виды цен" Style="{StaticResource ModuleTabStyle}" Click="HandleModuleTabClick" />
                <Button x:Name="DiscountsTabButton" Tag="discounts" Content="Скидки" Style="{StaticResource ModuleTabStyle}" Click="HandleModuleTabClick" />
                <Button x:Name="PriceSetupTabButton" Tag="priceSetup" Content="Установка цен" Style="{StaticResource ModuleTabStyle}" Click="HandleModuleTabClick" />
                <Button x:Name="JournalTabButton" Tag="journal" Content="Журнал" Style="{StaticResource ModuleTabStyle}" Click="HandleModuleTabClick" />
            </WrapPanel>

            <Grid Grid.Row="3" Margin="0,0,0,14">
                <WrapPanel x:Name="ProductsFilterPanel">
                    <Border Width="270"
                            Style="{StaticResource TableFilterSearchContainerStyle}"
                            Margin="0,0,10,10">
                        <Grid>
                            <TextBox x:Name="TableSearchBox"
                                     Style="{StaticResource TableFilterSearchTextBoxStyle}"
                                     TextChanged="HandleSearchTextChanged" />
                            <TextBlock x:Name="TableSearchPlaceholderText"
                                        Text="Поиск по коду, названию или штрихкоду..."
                                        Style="{StaticResource TableFilterSearchPlaceholderStyle}" />
                            <TextBlock Style="{StaticResource TableFilterSearchIconStyle}" />
                        </Grid>
                    </Border>
                    <ComboBox x:Name="CategoryFilterCombo" Style="{StaticResource FilterComboStyle}" Margin="0,0,10,10" SelectionChanged="HandleFilterChanged" />
                    <ComboBox x:Name="WarehouseFilterCombo" Style="{StaticResource FilterComboStyle}" Margin="0,0,10,10" SelectionChanged="HandleFilterChanged" />
                    <ComboBox x:Name="SupplierFilterCombo" Style="{StaticResource FilterComboStyle}" Margin="0,0,10,10" SelectionChanged="HandleFilterChanged" />
                    <ComboBox x:Name="StatusFilterCombo" Style="{StaticResource FilterComboStyle}" Margin="0,0,10,10" SelectionChanged="HandleFilterChanged" />
                    <CheckBox x:Name="OnlyProblemsCheckBox" Content="Только проблемные" Style="{StaticResource ProblemsOnlyStyle}" Margin="2,0,18,10" Checked="HandleFilterChanged" Unchecked="HandleFilterChanged" />
                    <Button Content="Сбросить" Style="{StaticResource TableFilterResetButtonStyle}" Margin="0,0,10,10" Click="HandleResetFiltersClick" />
                </WrapPanel>

                <StackPanel x:Name="SecondaryToolbarPanel" Visibility="Collapsed" Orientation="Horizontal">
                    <Button x:Name="SecondaryCreateButton" Content="Создать" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,0" Click="HandleSecondaryCreateClick" />
                    <Button x:Name="SecondaryEditButton" Content="Изменить" Style="{StaticResource GhostButtonStyle}" Margin="0,0,10,0" Click="HandleSecondaryEditClick" />
                    <Button x:Name="SecondaryApplyButton" Content="Провести" Style="{StaticResource GhostButtonStyle}" Margin="0,0,10,0" Click="HandleSecondaryApplyClick" />
                </StackPanel>
            </Grid>

            <Border x:Name="BulkActionsPanel"
                    Grid.Row="4"
                    Style="{StaticResource TableBulkBarStyle}"
                    CornerRadius="12,12,0,0"
                    Visibility="Collapsed">
                <WrapPanel>
                    <TextBlock x:Name="SelectedCountText"
                               Text="Выбрано 0 товаров"
                               Margin="0,0,18,0"
                               Style="{StaticResource TableBulkTextStyle}" />
                    <Button Content="Экспорт выбранных" Style="{StaticResource TableBulkActionButtonStyle}" Margin="0,0,8,0" Click="HandleExportSelectedClick" />
                    <Button Content="Печать этикеток" Style="{StaticResource TableBulkActionButtonStyle}" Margin="0,0,8,0" Click="HandlePrintLabelsClick" />
                    <Button Content="Изменить категорию" Style="{StaticResource TableBulkActionButtonStyle}" Margin="0,0,8,0" Click="HandleChangeCategoryClick" />
                    <Button Content="Изменить статус" Style="{StaticResource TableBulkActionButtonStyle}" Margin="0,0,8,0" Click="HandleChangeStatusClick" />
                    <Button Content="Обновить цены" Style="{StaticResource TableBulkActionButtonStyle}" Margin="0,0,8,0" Click="HandleUpdatePricesClick" />
                    <Button Content="Архивировать" Style="{StaticResource TableBulkActionButtonStyle}" Margin="0,0,8,0" Click="HandleArchiveSelectedClick" />
                    <Button Content="×" Style="{StaticResource TableBulkCloseButtonStyle}" Click="HandleClearSelectionClick" />
                </WrapPanel>
            </Border>

            <Grid Grid.Row="5">
                <Grid x:Name="ProductsContentGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" MinWidth="760" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="330" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="ProductsTableCard" Grid.Row="0" Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0" MinHeight="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DataGrid x:Name="ProductsGrid"
                                      Grid.Row="0"
                                      ItemsSource="{Binding Products}"
                                      SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                                      Style="{StaticResource ProductGridStyle}"
                                      ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                      RowStyle="{StaticResource GridRowStyle}"
                                      CellStyle="{StaticResource GridCellStyle}"
                                      MouseDoubleClick="HandleProductsGridDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Width="42" IsReadOnly="False">
                                        <DataGridTemplateColumn.Header>
                                            <CheckBox x:Name="SelectAllCheckBox" Click="HandleSelectAllClick" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Click="HandleRowCheckBoxClick" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Артикул / код" Binding="{Binding Code}" Width="92" IsReadOnly="True" />
                                    <DataGridTemplateColumn Header="Товар" Width="1.7*" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#1B2440" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding UnitDisplay}" Margin="0,3,0,0" Foreground="#7A86A5" FontSize="11" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="100" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Склад" Binding="{Binding Warehouse}" Width="112" IsReadOnly="True" />
                                    <DataGridTemplateColumn Header="Остаток" Width="125" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding FreeDisplay}" FontWeight="SemiBold" Foreground="#1B2440" />
                                                    <StackPanel Orientation="Horizontal" Height="5" Margin="0,4,0,4">
                                                        <Border Width="{Binding FreeBarWidth}" Background="#2FB36B" CornerRadius="2,0,0,2" />
                                                        <Border Width="{Binding ReservedBarWidth}" Background="#FF9F1A" />
                                                        <Border Width="{Binding TransitBarWidth}" Background="#4F75FF" CornerRadius="0,2,2,0" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding StockRatio}" Foreground="#64718F" FontSize="11" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Резерв" Binding="{Binding ReservedDisplay}" Width="70" IsReadOnly="True" />
                                    <DataGridTextColumn Header="В пути" Binding="{Binding InTransitDisplay}" Width="68" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Мин. остаток" Binding="{Binding MinimumStockDisplay}" Width="84" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Цена" Binding="{Binding PriceDisplay}" Width="86" IsReadOnly="True" />
                                    <DataGridTemplateColumn Header="Статус" Width="92" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding StatusBackground}" CornerRadius="7" Padding="8,4" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Status}" Foreground="{Binding StatusForeground}" FontSize="11" FontWeight="SemiBold" />
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Штрихкод" Binding="{Binding Barcode}" Width="118" IsReadOnly="True" />
                                    <DataGridTemplateColumn Header="Действия" Width="66" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="&#xE712;" AutomationProperties.Name="Действия товара" Tag="{Binding}" Style="{StaticResource TableRowActionButtonStyle}" Click="HandleRowActionsClick" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Grid Grid.Row="1" Style="{StaticResource TableFooterGridStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="ProductsCountText" Style="{StaticResource TableFooterTextStyle}" />
                                <StackPanel Grid.Column="1" Style="{StaticResource TablePagerPanelStyle}">
                                    <TextBlock Text="Прокрутка колесом" Style="{StaticResource TableFooterTextStyle}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border x:Name="ProductDetailsCard" Grid.Row="0" Grid.Column="2" Style="{StaticResource CardStyle}" Padding="16" MinHeight="0">
                        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="DetailNameText" Text="Выберите товар" FontSize="17" FontWeight="SemiBold" Foreground="#17213A" TextWrapping="Wrap" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                                        <Border x:Name="DetailStatusPill" CornerRadius="7" Padding="8,4" Background="#EAF9F0" VerticalAlignment="Top">
                                            <TextBlock x:Name="DetailStatusText" Text="Активный" Foreground="#1AA65F" FontSize="11" FontWeight="SemiBold" />
                                        </Border>
                                        <Button Content="&#xE712;" AutomationProperties.Name="Действия выбранного товара" Margin="8,0,0,0" Style="{StaticResource TableRowActionButtonStyle}" Click="HandleDetailActionsClick" />
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="78" Height="78" CornerRadius="8" Background="#F1F4FB" BorderBrush="#E1E7F3" BorderThickness="1">
                                        <Grid>
                                            <Rectangle Width="64" Height="36" RadiusX="6" RadiusY="6" Fill="#1C1F25" RenderTransformOrigin="0.5,0.5">
                                                <Rectangle.RenderTransform>
                                                    <RotateTransform Angle="-18" />
                                                </Rectangle.RenderTransform>
                                            </Rectangle>
                                            <Rectangle Width="44" Height="12" Fill="#3A3E47" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xEECA;" Foreground="#FFFFFF" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                    <Grid Grid.Column="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Артикул / код" Foreground="#7280A0" FontSize="11" />
                                            <TextBlock x:Name="DetailCodeText" Margin="0,4,0,8" Foreground="#1B2440" FontSize="12.5" FontWeight="SemiBold" />
                                            <TextBlock Text="Категория" Foreground="#7280A0" FontSize="11" />
                                            <TextBlock x:Name="DetailCategoryText" Margin="0,4,0,8" Foreground="#1B2440" FontSize="12.5" />
                                            <TextBlock Text="Поставщик" Foreground="#7280A0" FontSize="11" />
                                            <TextBlock x:Name="DetailSupplierText" Margin="0,4,0,8" Foreground="#1B2440" FontSize="12.5" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Склад по умолчанию" Foreground="#7280A0" FontSize="11" />
                                            <TextBlock x:Name="DetailWarehouseText" Margin="0,4,0,8" Foreground="#1B2440" FontSize="12.5" />
                                            <TextBlock Text="Ед. изм." Foreground="#7280A0" FontSize="11" />
                                            <TextBlock x:Name="DetailUnitText" Margin="0,4,0,8" Foreground="#1B2440" FontSize="12.5" />
                                            <TextBlock Text="Цена" Foreground="#7280A0" FontSize="11" />
                                            <TextBlock x:Name="DetailPriceText" Margin="0,4,0,8" Foreground="#1B2440" FontSize="12.5" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>

                                <StackPanel Margin="0,4,0,0">
                                    <TextBlock Text="Штрихкод" Foreground="#7280A0" FontSize="11" />
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock x:Name="DetailBarcodeText" Foreground="#1B2440" FontSize="12.5" />
                                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE8C8;" Margin="8,0,0,0" Foreground="#6B7794" />
                                    </StackPanel>
                                    <TextBlock Text="QR код" Margin="0,10,0,4" Foreground="#7280A0" FontSize="11" />
                                    <Border Width="34" Height="34" CornerRadius="4" Background="#F2F5FA" HorizontalAlignment="Left">
                                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE8A5;" Foreground="#1B2440" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </StackPanel>

                                <TextBlock x:Name="StockCaptionText" Text="Остатки" Margin="0,18,0,10" Foreground="#17213A" FontSize="13" FontWeight="SemiBold" />
                                <UniformGrid Columns="3">
                                    <Border Background="#EBF9F0" CornerRadius="8" Padding="10" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock x:Name="DetailFreeText" Text="0" Foreground="#1FA45F" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <TextBlock Text="Свободно" Foreground="#1FA45F" FontSize="11" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#FFF4E3" CornerRadius="8" Padding="10" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock x:Name="DetailReservedText" Text="0" Foreground="#FF8A00" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <TextBlock Text="В резерве" Foreground="#B86A00" FontSize="11" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#EEF2FF" CornerRadius="8" Padding="10">
                                        <StackPanel>
                                            <TextBlock x:Name="DetailTransitText" Text="0" Foreground="#4F5BFF" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <TextBlock Text="В пути" Foreground="#4F5BFF" FontSize="11" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <Grid Margin="0,12,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Минимальный остаток" Foreground="#7280A0" FontSize="11" />
                                        <TextBlock x:Name="DetailMinimumText" Text="0" Margin="0,4,0,0" Foreground="#17213A" FontSize="13" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Дефицит" Foreground="#7280A0" FontSize="11" />
                                        <TextBlock x:Name="DetailDeficitText" Text="0" Margin="0,4,0,0" Foreground="#FF3045" FontSize="13" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Grid>

                                <Border Height="1" Background="#EEF2FA" Margin="0,0,0,14" />
                                <Grid>
                                    <TextBlock Text="Последние движения" Foreground="#17213A" FontSize="13" FontWeight="SemiBold" />
                                    <Button Content="Все движения" HorizontalAlignment="Right" BorderThickness="0" Background="Transparent" Foreground="#4F5BFF" FontSize="11.5" Click="HandleMovementsClick" />
                                </Grid>
                                <ItemsControl x:Name="MovementsItemsControl" Margin="0,8,0,14">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="82" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Date}" Foreground="#7280A0" FontSize="11" />
                                                <TextBlock Grid.Column="1" Text="{Binding Title}" Foreground="#53617E" FontSize="11" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="2" Text="{Binding Quantity}" Foreground="{Binding QuantityBrush}" FontSize="11" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Связанные документы" Foreground="#17213A" FontSize="13" FontWeight="SemiBold" />
                                <ItemsControl x:Name="DocumentsItemsControl" Margin="0,8,0,14">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Margin="0,0,0,6" FontSize="11.5">
                                                <Run Text="{Binding Title}" Foreground="#4F5BFF" />
                                                <Run Text="  " />
                                                <Run Text="{Binding Date}" Foreground="#7280A0" />
                                                <Run Text="  " />
                                                <Run Text="{Binding Status}" Foreground="#53617E" />
                                            </TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Height="1" Background="#EEF2FA" Margin="0,0,0,14" />
                                <TextBlock Text="Быстрые действия" Foreground="#17213A" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <UniformGrid x:Name="DetailActionsGrid" Columns="2">
                                    <Button Content="Изменить" Style="{StaticResource MiniActionButtonStyle}" Margin="0,0,8,8" Click="HandleEditSelectedClick" />
                                    <Button Content="Печать этикетки" Style="{StaticResource MiniActionButtonStyle}" Margin="0,0,0,8" Click="HandlePrintLabelsClick" />
                                    <Button Content="Переместить" Style="{StaticResource MiniActionButtonStyle}" Margin="0,0,8,8" Click="HandleMoveSelectedClick" />
                                    <Button Content="Зарезервировать" Style="{StaticResource MiniActionButtonStyle}" Margin="0,0,0,8" Click="HandleReserveSelectedClick" />
                                    <Button Content="Списать" Style="{StaticResource MiniActionButtonStyle}" Margin="0,0,8,8" Click="HandleWriteOffSelectedClick" />
                                    <Button Content="Создать закупку" Style="{StaticResource MiniActionButtonStyle}" Margin="0,0,0,8" Click="HandlePurchaseSelectedClick" />
                                    <Button Content="Установить цену" Style="{StaticResource MiniActionButtonStyle}" Margin="0,0,8,0" Click="HandleUpdatePricesClick" />
                                </UniformGrid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <Border x:Name="SecondaryContentPanel" Visibility="Collapsed" Style="{StaticResource CardStyle}" Padding="18" MinHeight="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock x:Name="SecondaryTitleText" Text="Виды цен" FontSize="18" FontWeight="SemiBold" Foreground="#17213A" />
                            <TextBlock x:Name="SecondaryHintText" Margin="0,5,0,0" FontSize="12.5" Foreground="#7280A0" Text="Управление связанными справочниками каталога." />
                        </StackPanel>
                        <DataGrid x:Name="SecondaryDataGrid"
                                  Grid.Row="1"
                                  Style="{StaticResource ProductGridStyle}"
                                  ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                  RowStyle="{StaticResource GridRowStyle}"
                                  CellStyle="{StaticResource GridCellStyle}"
                                  IsReadOnly="True" />
                    </Grid>
                </Border>
            </Grid>
    </Grid>
</UserControl>
