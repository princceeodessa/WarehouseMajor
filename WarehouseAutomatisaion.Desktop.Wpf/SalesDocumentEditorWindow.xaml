<Window x:Class="WarehouseAutomatisaion.Desktop.Wpf.SalesDocumentEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Документ продаж"
        Width="1040"
        Height="760"
        MinWidth="960"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8FC">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E4EAF5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#6E7B98" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Height" Value="38" />
            <Setter Property="FontSize" Value="13.5" />
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="#4F5BFF" />
            <Setter Property="BorderBrush" Value="#4F5BFF" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D8DFF0" />
            <Setter Property="Foreground" Value="#25324A" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF2FA" />
            <Setter Property="VerticalGridLinesBrush" Value="#EEF2FA" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="RowHeight" Value="46" />
            <Setter Property="ColumnHeaderHeight" Value="40" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="RowHeaderWidth" Value="0" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#EEF2FA" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="#73809C" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock x:Name="HeaderTitleText"
                       FontSize="27"
                       FontWeight="SemiBold"
                       Foreground="#17213A" />
            <TextBlock x:Name="HeaderSubtitleText"
                       Margin="0,6,0,0"
                       FontSize="13.5"
                       Foreground="#6E7B98" />
        </StackPanel>

        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}"
                Padding="18"
                Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,14">
                    <TextBlock Text="Номер" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="NumberTextBox" Style="{StaticResource InputStyle}" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,14">
                    <TextBlock x:Name="DocumentDateLabelText" Text="Дата" Style="{StaticResource FieldLabelStyle}" />
                    <DatePicker x:Name="DocumentDatePicker" Style="{StaticResource InputStyle}" />
                </StackPanel>
                <StackPanel x:Name="SecondaryDatePanel" Grid.Row="0" Grid.Column="4" Margin="0,0,0,14">
                    <TextBlock x:Name="SecondaryDateLabelText" Text="Срок оплаты" Style="{StaticResource FieldLabelStyle}" />
                    <DatePicker x:Name="SecondaryDatePicker" Style="{StaticResource InputStyle}" />
                </StackPanel>

                <StackPanel x:Name="CustomerPanel" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,14">
                    <TextBlock Text="Клиент" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="CustomerComboBox" Style="{StaticResource InputStyle}" SelectionChanged="HandleCustomerSelectionChanged" />
                </StackPanel>
                <StackPanel x:Name="OrderPanel" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,14">
                    <TextBlock Text="Основание / заказ" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="OrderComboBox" Style="{StaticResource InputStyle}" SelectionChanged="HandleOrderSelectionChanged" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="4" Margin="0,0,0,14">
                    <TextBlock Text="Статус" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="StatusComboBox" Style="{StaticResource InputStyle}" />
                </StackPanel>

                <StackPanel x:Name="WarehousePanel" Grid.Row="2" Grid.Column="0" Margin="0,0,0,14">
                    <TextBlock Text="Склад" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="WarehouseComboBox" Style="{StaticResource InputStyle}" IsEditable="True" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,14">
                    <TextBlock Text="Менеджер" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="ManagerComboBox" Style="{StaticResource InputStyle}" IsEditable="True" />
                </StackPanel>
                <StackPanel x:Name="CurrencyPanel" Grid.Row="2" Grid.Column="4" Margin="0,0,0,14">
                    <TextBlock Text="Валюта" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="CurrencyComboBox" Style="{StaticResource InputStyle}" />
                </StackPanel>
                <StackPanel x:Name="CarrierPanel" Grid.Row="2" Grid.Column="4" Margin="0,0,0,14">
                    <TextBlock Text="Способ доставки" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="CarrierTextBox" Style="{StaticResource InputStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="5">
                    <TextBlock Text="Комментарий" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="CommentTextBox"
                             Height="78"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Позиции" FontSize="18" FontWeight="SemiBold" Foreground="#17213A" />
                        <TextBlock x:Name="LinesHintText" Margin="0,4,0,0" FontSize="12.5" Foreground="#6E7B98" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Добавить позицию" Style="{StaticResource GhostButtonStyle}" Margin="0,0,10,0" Click="HandleAddLineClick" />
                        <Button Content="Изменить" Style="{StaticResource GhostButtonStyle}" Margin="0,0,10,0" Click="HandleEditLineClick" />
                        <Button Content="Удалить" Style="{StaticResource GhostButtonStyle}" Click="HandleRemoveLineClick" />
                    </StackPanel>
                </Grid>

                <DataGrid x:Name="LinesGrid" Grid.Row="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Код" Binding="{Binding ItemCode}" Width="1*" />
                        <DataGridTextColumn Header="Товар" Binding="{Binding ItemName}" Width="2.8*" />
                        <DataGridTextColumn Header="Ед." Binding="{Binding Unit}" Width="0.6*" />
                        <DataGridTextColumn Header="Кол-во" Binding="{Binding QuantityDisplay}" Width="0.9*" />
                        <DataGridTextColumn Header="Цена" Binding="{Binding PriceDisplay}" Width="1*" />
                        <DataGridTextColumn Header="Сумма" Binding="{Binding AmountDisplay}" Width="1*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="0,18,0,0">
            <StackPanel>
                <TextBlock x:Name="TotalText" FontSize="14" FontWeight="SemiBold" Foreground="#17213A" />
                <TextBlock x:Name="ValidationText" Margin="0,5,0,0" Foreground="#D92D20" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена"
                        Width="120"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="0,0,10,0"
                        Click="HandleCancelClick" />
                <Button Content="Сохранить документ"
                        Width="180"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="HandleSaveClick" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
