<Window x:Class="WarehouseAutomatisaion.Desktop.Wpf.SalesDocumentLinksWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="1080"
        Height="720"
        MinWidth="920"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Title="Связанные документы"
        Background="#F7F9FD">
    <Window.Resources>
        <Style TargetType="DataGrid" BasedOn="{StaticResource DialogDataGridStyle}">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="RowHeight" Value="44" />
            <Setter Property="CanUserSortColumns" Value="True" />
        </Style>
        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DialogDataGridHeaderStyle}" />

        <Style x:Key="SummaryCardStyle" TargetType="Border" BasedOn="{StaticResource DialogCardStyle}">
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="MinHeight" Value="104" />
        </Style>

        <Style x:Key="SummaryLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6E7B98" />
            <Setter Property="FontSize" Value="12.5" />
        </Style>

        <Style x:Key="SummaryValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#07142F" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SummaryHintStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7180A0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,5,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="188" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock x:Name="HeaderTitleText"
                           FontSize="27"
                           FontWeight="SemiBold"
                           Foreground="#07142F" />
                <TextBlock x:Name="HeaderSubtitleText"
                           Margin="0,6,0,0"
                           FontSize="13.5"
                           Foreground="#6E7B98"
                           TextWrapping="Wrap" />
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Копировать список"
                    Style="{StaticResource DialogSecondaryButtonStyle}"
                    Margin="18,2,0,0"
                    VerticalAlignment="Top"
                    Click="HandleCopyClick" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,20,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SummaryCardStyle}">
                <StackPanel>
                    <TextBlock Text="Заказ" Style="{StaticResource SummaryLabelStyle}" />
                    <TextBlock x:Name="OrderSummaryValueText" Style="{StaticResource SummaryValueStyle}" />
                    <TextBlock x:Name="OrderSummaryHintText" Style="{StaticResource SummaryHintStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource SummaryCardStyle}">
                <StackPanel>
                    <TextBlock Text="Клиент" Style="{StaticResource SummaryLabelStyle}" />
                    <TextBlock x:Name="CustomerSummaryValueText" Style="{StaticResource SummaryValueStyle}" />
                    <TextBlock x:Name="CustomerSummaryHintText" Style="{StaticResource SummaryHintStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource SummaryCardStyle}">
                <StackPanel>
                    <TextBlock Text="Документы" Style="{StaticResource SummaryLabelStyle}" />
                    <TextBlock x:Name="DocumentSummaryValueText" Style="{StaticResource SummaryValueStyle}" />
                    <TextBlock x:Name="DocumentSummaryHintText" Style="{StaticResource SummaryHintStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="6" Style="{StaticResource SummaryCardStyle}">
                <StackPanel>
                    <TextBlock Text="Оплата в кассу" Style="{StaticResource SummaryLabelStyle}" />
                    <TextBlock x:Name="CashSummaryValueText" Style="{StaticResource SummaryValueStyle}" />
                    <TextBlock x:Name="CashSummaryHintText" Style="{StaticResource SummaryHintStyle}" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource DialogCardStyle}"
                Padding="0">
            <DataGrid x:Name="DocumentsGrid"
                      AlternatingRowBackground="#F8FAFF">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Документ" Binding="{Binding Kind}" Width="150" />
                    <DataGridTextColumn Header="Номер" Binding="{Binding Number}" Width="145" />
                    <DataGridTextColumn Header="Дата" Binding="{Binding DateText}" Width="110" />
                    <DataGridTextColumn Header="Клиент" Binding="{Binding CustomerName}" Width="1.35*" />
                    <DataGridTextColumn Header="Сумма" Binding="{Binding AmountText}" Width="130" />
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="130" />
                    <DataGridTextColumn Header="Связь" Binding="{Binding Relation}" Width="165" />
                    <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" Width="1.45*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="4"
                Style="{StaticResource DialogCardStyle}"
                Padding="0">
            <Grid>
                <DataGrid x:Name="OperationLogGrid"
                          AlternatingRowBackground="#F8FAFF">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата" Binding="{Binding DateText}" Width="140" />
                        <DataGridTextColumn Header="Документ" Binding="{Binding Entity}" Width="165" />
                        <DataGridTextColumn Header="Действие" Binding="{Binding Action}" Width="175" />
                        <DataGridTextColumn Header="Результат" Binding="{Binding Result}" Width="115" />
                        <DataGridTextColumn Header="Сообщение" Binding="{Binding Message}" Width="2*" />
                        <DataGridTextColumn Header="Пользователь" Binding="{Binding Actor}" Width="140" />
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock x:Name="EmptyLogText"
                           Text="По этой цепочке пока нет записей журнала."
                           Foreground="#6E7B98"
                           FontSize="14"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="5"
                    Margin="0,18,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Закрыть"
                    Style="{StaticResource DialogPrimaryButtonStyle}"
                    Width="128"
                    Click="HandleCloseClick" />
        </StackPanel>
    </Grid>
</Window>
