<UserControl x:Class="WarehouseAutomatisaion.Desktop.Wpf.DashboardWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#F7F9FF">
    <UserControl.Resources>
        <Style x:Key="PageCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E8EDF8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E4EAF5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#4D5B79" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter Margin="18,16"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconCircleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E4EAF5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#6A7898" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled" Background="#F7F9FF">
        <Grid Margin="28,20,28,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,26">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="GreetingTitleText"
                               FontSize="34"
                               FontWeight="SemiBold"
                               Foreground="#1A2440" />
                    <TextBlock x:Name="GreetingSubtitleText"
                               Margin="0,8,0,0"
                               FontSize="15"
                               Foreground="#7280A0" />
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Border Width="320"
                                Height="42"
                                Background="#FFFFFF"
                                BorderBrush="#E4EAF5"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14,0,14,0">
                            <Grid>
                                <TextBox x:Name="HeaderSearchBox"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                          TextChanged="HandleSearchTextChanged"
                                          KeyDown="HandleSearchKeyDown" />
                                <TextBlock x:Name="HeaderSearchPlaceholderText"
                                           Text="Поиск по заказам, клиентам, счетам..."
                                           FontSize="14"
                                           Foreground="#9AA5BD"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False" />
                                <TextBlock FontFamily="Segoe Fluent Icons"
                                           Text="&#xE721;"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Foreground="#909AB5"
                                           FontSize="14" />
                            </Grid>
                        </Border>
                        <Button Style="{StaticResource IconCircleButtonStyle}"
                                Tag="audit"
                                ToolTip="Открыть отчеты и сигналы"
                                Click="HandleNavigationButtonClick">
                            <Grid>
                                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE7F4;" FontSize="14" />
                                <Border Width="16" Height="16" Background="#FF5F6D" CornerRadius="8" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0">
                                    <TextBlock x:Name="NotificationBadgeText" Foreground="White" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource IconCircleButtonStyle}"
                                Tag="model"
                                ToolTip="Открыть связи данных"
                                Click="HandleNavigationButtonClick">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE897;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,0,0,22">
                <TextBlock Text="Быстрые переходы"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#1A2440" />
                <ItemsControl x:Name="QuickLinksItemsControl" Margin="0,14,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource ActionButtonStyle}"
                                    Width="246"
                                    Height="124"
                                    Margin="0,0,16,16"
                                    Tag="{Binding TargetKey}"
                                    Click="HandleNavigationButtonClick">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="42" Height="42" Background="{Binding IconBackground}" CornerRadius="14">
                                            <TextBlock Text="{Binding IconGlyph}"
                                                       FontFamily="Segoe Fluent Icons"
                                                       FontSize="18"
                                                       Foreground="{Binding AccentBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="{Binding Title}"
                                                   Margin="14,7,0,0"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="#1A2440" />
                                    </StackPanel>
                                    <Grid Grid.Row="1" Margin="56,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Subtitle}"
                                                   FontSize="14"
                                                   Foreground="#7280A0"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="150" />
                                        <TextBlock Grid.Column="1"
                                                   Text="→"
                                                   FontSize="18"
                                                   Foreground="#7D8BB0"
                                                   VerticalAlignment="Bottom" />
                                    </Grid>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <Grid x:Name="MainInsightsGrid" Grid.Row="2" Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="UrgentTasksCard" Margin="0,0,18,0" Padding="18" Style="{StaticResource PageCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Срочные задачи"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#1A2440" />
                            <Border Background="#FFECEE" CornerRadius="10" Padding="6,2" Margin="10,0,0,0">
                                <TextBlock x:Name="UrgentTaskBadgeText" Foreground="#FF5F6D" FontSize="12" FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>
                        <ItemsControl x:Name="UrgentTasksItemsControl" Margin="0,16,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Tag="{Binding TargetKey}"
                                            Click="HandleNavigationButtonClick"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            Margin="0,0,0,14"
                                            HorizontalContentAlignment="Stretch"
                                            Cursor="Hand">
                                        <Border BorderBrush="#EEF2FA" BorderThickness="1" CornerRadius="16" Padding="14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="42" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="40" Height="40" Background="{Binding IconBackground}" CornerRadius="14">
                                                    <TextBlock Text="{Binding IconGlyph}"
                                                               FontFamily="Segoe Fluent Icons"
                                                               FontSize="18"
                                                               Foreground="{Binding AccentBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                    <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" Foreground="#1A2440" />
                                                    <TextBlock Text="{Binding Subtitle}" Margin="0,4,0,0" FontSize="13" Foreground="#7280A0" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding Value}" FontSize="26" FontWeight="SemiBold" Foreground="{Binding AccentBrush}" HorizontalAlignment="Right" />
                                                    <TextBlock Text="→" FontSize="16" Foreground="#7D8BB0" HorizontalAlignment="Right" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Tag="sales"
                                Click="HandleNavigationButtonClick"
                                Style="{StaticResource GhostButtonStyle}"
                                Margin="0,6,0,0"
                                HorizontalAlignment="Stretch"
                                Content="Перейти ко всем задачам" />
                    </StackPanel>
                </Border>

                <Border x:Name="AnalyticsCard" Grid.Column="1" Padding="18" Style="{StaticResource PageCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Аналитика"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#1A2440" />
                            <Border Grid.Column="1"
                                    Background="#FFFFFF"
                                    BorderBrush="#E4EAF5"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="14,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE787;" Foreground="#7280A0" FontSize="13" Margin="0,0,8,0" />
                                    <TextBlock x:Name="AnalyticsRangeText" FontSize="13" Foreground="#42506D" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <ItemsControl x:Name="AnalyticsMetricsItemsControl" Grid.Row="1" Margin="0,16,0,16">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="150" MinHeight="126" Margin="0,0,14,14" Style="{StaticResource MetricCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" Style="{StaticResource MetricCaptionStyle}" />
                                            <TextBlock Text="{Binding Value}" Margin="0,16,0,0" Style="{StaticResource MetricValueStyle}" />
                                            <TextBlock Text="{Binding Delta}" Margin="0,12,0,0" FontWeight="SemiBold" Foreground="{Binding DeltaBrush}" Style="{StaticResource MetricHintStyle}" />
                                            <TextBlock Text="к прошлому периоду" Style="{StaticResource MetricHintStyle}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid x:Name="AnalyticsChartsGrid" Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.65*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border x:Name="RevenueChartCard" Margin="0,0,18,0" Padding="16" Style="{StaticResource PageCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Выручка" FontSize="16" FontWeight="SemiBold" Foreground="#1A2440" />
                                        <TextBlock Text="    " />
                                        <TextBlock Text="●" Foreground="#4F5BFF" FontSize="16" />
                                        <TextBlock Text=" Выручка" FontSize="13" Foreground="#7280A0" />
                                        <TextBlock Text="    " />
                                        <TextBlock Text="●" Foreground="#BBC4D9" FontSize="16" />
                                        <TextBlock Text=" Прошлый период" FontSize="13" Foreground="#7280A0" />
                                    </StackPanel>
                                    <Canvas x:Name="RevenueChartCanvas" Grid.Row="1" Height="250" Margin="0,12,0,0" />
                                </Grid>
                            </Border>

                            <Border x:Name="StatusChartCard" Grid.Column="1" Padding="16" Style="{StaticResource PageCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Заказы по статусам" FontSize="16" FontWeight="SemiBold" Foreground="#1A2440" />
                                    <Grid x:Name="StatusChartBodyGrid" Grid.Row="1" Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Canvas x:Name="StatusDonutCanvas" Width="220" Height="220" HorizontalAlignment="Left" />
                                        <ItemsControl x:Name="StatusLegendItemsControl" Grid.Column="1" Margin="12,8,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Ellipse Width="10" Height="10" Fill="{Binding ColorBrush}" Margin="0,4,10,0" />
                                                        <TextBlock Grid.Column="1" Text="{Binding Label}" FontSize="13" Foreground="#4F5BFF" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="2" Text="{Binding ValueText}" FontSize="13" Foreground="#7280A0" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="3" Padding="18" Style="{StaticResource PageCardStyle}">
                <StackPanel>
                    <TextBlock Text="Срочные действия"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#1A2440" />
                    <ItemsControl x:Name="QuickActionItemsControl" Margin="0,16,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="246" MinHeight="178" Margin="0,0,16,16" Padding="18,16" Style="{StaticResource PageCardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="42" Height="42" Background="{Binding IconBackground}" CornerRadius="14">
                                                <TextBlock Text="{Binding IconGlyph}"
                                                           FontFamily="Segoe Fluent Icons"
                                                           FontSize="18"
                                                           Foreground="{Binding AccentBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                             <TextBlock Text="{Binding Title}"
                                                        Margin="14,2,0,0"
                                                        FontSize="15"
                                                        FontWeight="SemiBold"
                                                        Foreground="#1A2440"
                                                        TextWrapping="Wrap"
                                                        MaxWidth="148" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Margin="0,14,0,0">
                                             <TextBlock Text="{Binding Subtitle}" FontSize="13" Foreground="#7280A0" TextWrapping="Wrap" />
                                             <TextBlock Text="{Binding Hint}" Margin="0,8,0,0" FontSize="12" Foreground="#98A5BE" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <Button Grid.Row="2"
                                                Tag="{Binding TargetKey}"
                                                Click="HandleNavigationButtonClick"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Margin="0,10,0,0"
                                                Content="Открыть" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
