<Window x:Class="WarehouseAutomatisaion.Desktop.Wpf.WarehouseStorageCellEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="760"
        Height="620"
        MinWidth="720"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F7F9FD">
    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource DialogFieldLabelStyle}" />
        <Style x:Key="InputStyle" TargetType="Control" BasedOn="{StaticResource DialogInputStyle}" />
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock x:Name="HeaderTitleText"
                       FontSize="25"
                       FontWeight="SemiBold"
                       Foreground="#17213A" />
            <TextBlock Text="Адрес ячейки используется в приемке, перемещениях, остатках и подборе отгрузки. QR пока только подготовлен."
                       Margin="0,6,0,0"
                       FontSize="13"
                       Foreground="#6E7B98"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1"
                Style="{StaticResource DialogCardStyle}"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,14">
                    <TextBlock Text="Склад" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="WarehouseComboBox" Style="{StaticResource InputStyle}" IsEditable="True" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,14">
                    <TextBlock Text="Код ячейки" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="CodeTextBox" Style="{StaticResource InputStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,14">
                    <TextBlock Text="Код зоны" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="ZoneCodeTextBox" Style="{StaticResource InputStyle}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,14">
                    <TextBlock Text="Зона" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="ZoneNameTextBox" Style="{StaticResource InputStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,14">
                    <TextBlock Text="Тип ячейки" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="CellTypeComboBox" Style="{StaticResource InputStyle}" IsEditable="True" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,14">
                    <TextBlock Text="Статус" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="StatusComboBox" Style="{StaticResource InputStyle}" IsEditable="True" />
                </StackPanel>

                <UniformGrid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Columns="4" Margin="0,0,0,14">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Ряд" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="RowTextBox" Style="{StaticResource InputStyle}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Стеллаж" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="RackTextBox" Style="{StaticResource InputStyle}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Полка" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="ShelfTextBox" Style="{StaticResource InputStyle}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Место" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="CellTextBox" Style="{StaticResource InputStyle}" />
                    </StackPanel>
                </UniformGrid>

                <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,0,14">
                    <TextBlock Text="Лимит вместимости" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="CapacityTextBox" Style="{StaticResource InputStyle}" />
                </StackPanel>
                <StackPanel Grid.Row="4" Grid.Column="2" Margin="0,0,0,14">
                    <TextBlock Text="QR payload" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="QrPayloadTextBox" Style="{StaticResource InputStyle}" IsReadOnly="True" />
                </StackPanel>

                <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3">
                    <TextBlock Text="Комментарий" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="CommentTextBox"
                             Style="{StaticResource DialogMultilineTextBoxStyle}"
                             Height="86"
                             VerticalScrollBarVisibility="Hidden" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <TextBlock x:Name="ValidationText"
                       Foreground="#D92D20"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена"
                        Style="{StaticResource DialogSecondaryButtonStyle}"
                        Width="120"
                        Margin="0,0,10,0"
                        Click="HandleCancelClick" />
                <Button Content="Сохранить"
                        Style="{StaticResource DialogPrimaryButtonStyle}"
                        Width="150"
                        Click="HandleSaveClick" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
