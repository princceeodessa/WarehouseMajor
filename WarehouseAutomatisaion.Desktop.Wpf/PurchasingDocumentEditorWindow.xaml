<Window x:Class="WarehouseAutomatisaion.Desktop.Wpf.PurchasingDocumentEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Закупка"
        Height="760"
        Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="#F7F9FD">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBrush" Color="#F7F9FD" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="LineBrush" Color="#E7ECF7" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#4F5BFF" />
        <SolidColorBrush x:Key="TextBrush" Color="#17213A" />
        <SolidColorBrush x:Key="MutedBrush" Color="#7A86A5" />

        <Style x:Key="CardStyle" TargetType="Border" BasedOn="{StaticResource DialogCardStyle}">
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource DialogFieldLabelStyle}" />

        <Style x:Key="TextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource DialogTextBoxStyle}" />

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource DialogComboBoxStyle}" />

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogPrimaryButtonStyle}" />

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogSecondaryButtonStyle}" />

        <Style x:Key="GridStyle" TargetType="DataGrid" BasedOn="{StaticResource DialogDataGridStyle}">
            <Setter Property="CanUserResizeColumns" Value="False" />
            <Setter Property="CanUserSortColumns" Value="False" />
            <Setter Property="RowHeight" Value="48" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PageBrush}" Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="4,0,4,18">
            <TextBlock x:Name="HeaderTitleText" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
            <TextBlock x:Name="HeaderSubtitleText" Margin="0,6,0,0" FontSize="13.5" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="18" Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,14">
                    <TextBlock Text="Номер" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="NumberTextBox" Style="{StaticResource TextBoxStyle}" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="12,0,12,14">
                    <TextBlock Text="Дата" Style="{StaticResource FieldLabelStyle}" />
                    <DatePicker x:Name="DocumentDatePicker" Style="{StaticResource DialogDatePickerStyle}" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="12,0,0,14">
                    <TextBlock Text="Статус" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="StatusComboBox" Style="{StaticResource ComboBoxStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Поставщик" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="SupplierComboBox" Style="{StaticResource ComboBoxStyle}" DisplayMemberPath="Name" SelectionChanged="HandleSupplierSelectionChanged" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,0,12,0">
                    <TextBlock Text="Склад" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="WarehouseComboBox" Style="{StaticResource ComboBoxStyle}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Margin="12,0,0,0">
                    <TextBlock Text="Договор" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="ContractTextBox" Style="{StaticResource TextBoxStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Позиции закупки" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="Добавьте позиции номенклатуры, цену закупки и плановую дату." Margin="0,6,0,0" FontSize="13" Foreground="{StaticResource MutedBrush}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,16,0,12">
                    <Button Content="Добавить позицию" Style="{StaticResource GhostButtonStyle}" Margin="0,0,10,0" Click="HandleAddLineClick" />
                    <Button Content="Изменить позицию" Style="{StaticResource GhostButtonStyle}" Margin="0,0,10,0" Click="HandleEditLineClick" />
                    <Button Content="Удалить позицию" Style="{StaticResource GhostButtonStyle}" Click="HandleRemoveLineClick" />
                </StackPanel>

                <DataGrid x:Name="LinesGrid" Grid.Row="2" Style="{StaticResource GridStyle}" SelectionChanged="HandleLinesSelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Код" Binding="{Binding ItemCode}" Width="120" IsReadOnly="True" />
                        <DataGridTextColumn Header="Номенклатура" Binding="{Binding ItemName}" Width="*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Ед." Binding="{Binding Unit}" Width="70" IsReadOnly="True" />
                        <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity, StringFormat=N2}" Width="90" IsReadOnly="True" />
                        <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=N2}" Width="100" IsReadOnly="True" />
                        <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat=N2}" Width="110" IsReadOnly="True" />
                        <DataGridTextColumn x:Name="TargetLocationColumn" Header="Ячейка" Binding="{Binding TargetLocation}" Width="130" IsReadOnly="True" />
                        <DataGridTextColumn Header="План" Binding="{Binding PlannedDate, StringFormat=dd.MM.yyyy}" Width="110" IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock x:Name="TotalText" Grid.Row="3" Margin="0,12,0,0" FontSize="13.5" Foreground="#34415F" FontWeight="SemiBold" />
                <TextBlock x:Name="ValidationText" Grid.Row="4" Margin="0,12,0,0" Foreground="#E14B5A" FontSize="12.5" TextWrapping="Wrap" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Отмена" Style="{StaticResource GhostButtonStyle}" Margin="0,0,10,0" Click="HandleCancelClick" />
            <Button Content="Сохранить закупку" Style="{StaticResource PrimaryButtonStyle}" Click="HandleSaveClick" />
        </StackPanel>
    </Grid>
</Window>
