<Window x:Class="WarehouseAutomatisaion.Desktop.Wpf.WarehouseDocumentEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Документ склада"
        Width="1180"
        Height="820"
        MinWidth="1100"
        MinHeight="760"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8FC">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border" BasedOn="{StaticResource DialogCardStyle}">
            <Setter Property="BorderBrush" Value="#E8EDF7" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource DialogFieldLabelStyle}" />

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogPrimaryButtonStyle}" />

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogSecondaryButtonStyle}" />

        <Style TargetType="TextBox" BasedOn="{StaticResource DialogTextBoxStyle}" />

        <Style TargetType="ComboBox" BasedOn="{StaticResource DialogComboBoxStyle}" />

        <Style TargetType="DataGrid" BasedOn="{StaticResource DialogDataGridStyle}">
            <Setter Property="RowHeight" Value="48" />
            <Setter Property="ColumnHeaderHeight" Value="42" />
            <Setter Property="IsReadOnly" Value="True" />
        </Style>

        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DialogDataGridHeaderStyle}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="16,0,16,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock x:Name="HeaderTitleText"
                       FontSize="30"
                       FontWeight="SemiBold"
                       Foreground="#1B2440" />
            <TextBlock x:Name="HeaderSubtitleText"
                       Margin="0,8,0,0"
                       FontSize="14"
                       Foreground="#6E7B98"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,16">
                    <TextBlock Text="Номер" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="NumberTextBox" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="12,0,12,16">
                    <TextBlock Text="Дата" Style="{StaticResource FieldLabelStyle}" />
                    <DatePicker x:Name="DocumentDatePicker" Style="{StaticResource DialogDatePickerStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="12,0,0,16">
                    <TextBlock Text="Статус" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="StatusComboBox" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,16">
                    <TextBlock Text="Склад-источник" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="SourceWarehouseComboBox" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,0,12,16">
                    <TextBlock x:Name="TargetWarehouseLabelText" Text="Склад-получатель" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="TargetWarehouseComboBox" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2" Margin="12,0,0,16">
                    <TextBlock Text="Основание / ссылка" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="RelatedDocumentTextBox" />
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                    <TextBlock Text="Комментарий" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="CommentTextBox" Style="{StaticResource DialogMultilineTextBoxStyle}" Height="86" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="Позиции документа" FontSize="24" FontWeight="SemiBold" Foreground="#1B2440" />
                    <TextBlock x:Name="LinesSubtitleText" Margin="0,6,0,0" FontSize="14" Foreground="#6E7B98" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,14">
                    <Button Content="Добавить позицию" Style="{StaticResource GhostButtonStyle}" Margin="0,0,10,0" Click="HandleAddLineClick" />
                    <Button Content="Изменить позицию" Style="{StaticResource GhostButtonStyle}" Margin="0,0,10,0" Click="HandleEditLineClick" />
                    <Button Content="Удалить позицию" Style="{StaticResource GhostButtonStyle}" Click="HandleRemoveLineClick" />
                </StackPanel>

                <DataGrid x:Name="LinesGrid" Grid.Row="2" SelectionChanged="HandleLinesSelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Код" Binding="{Binding ItemCode}" Width="1.2*" />
                        <DataGridTextColumn Header="Номенклатура" Binding="{Binding ItemName}" Width="2.5*" />
                        <DataGridTextColumn Header="Ед." Binding="{Binding Unit}" Width="0.8*" />
                        <DataGridTextColumn Header="Количество" Binding="{Binding Quantity, StringFormat=N2}" Width="1*" />
                        <DataGridTextColumn Header="Источник" Binding="{Binding SourceLocation}" Width="1.6*" />
                        <DataGridTextColumn Header="Назначение" Binding="{Binding TargetLocation}" Width="1.6*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <DockPanel Grid.Row="3" Margin="0,18,0,0">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock x:Name="TotalText"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#1B2440" />
                <TextBlock x:Name="ValidationText"
                           Margin="0,6,0,0"
                           FontSize="13"
                           Foreground="#D04D4D" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Style="{StaticResource GhostButtonStyle}" Margin="0,0,10,0" Click="HandleCancelClick" />
                <Button Content="Сохранить" Style="{StaticResource PrimaryButtonStyle}" Click="HandleSaveClick" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
