<Window x:Class="WarehouseAutomatisaion.Desktop.Wpf.WarehouseDocumentEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Документ склада"
        Width="1180"
        Height="820"
        MinWidth="1100"
        MinHeight="760"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8FC">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E8EDF7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="Background" Value="#4F5BFF" />
            <Setter Property="BorderBrush" Value="#4F5BFF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D8DFF0" />
            <Setter Property="Foreground" Value="#25324A" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderBrush" Value="#D8DFF0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderBrush" Value="#D8DFF0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF2FA" />
            <Setter Property="VerticalGridLinesBrush" Value="#EEF2FA" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="RowHeight" Value="48" />
            <Setter Property="ColumnHeaderHeight" Value="42" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="RowHeaderWidth" Value="0" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#EEF2FA" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="#73809C" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,0,16,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock x:Name="HeaderTitleText"
                       FontSize="30"
                       FontWeight="SemiBold"
                       Foreground="#1B2440" />
            <TextBlock x:Name="HeaderSubtitleText"
                       Margin="0,8,0,0"
                       FontSize="14"
                       Foreground="#6E7B98"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,16">
                    <TextBlock Text="Номер" FontSize="13" FontWeight="SemiBold" Foreground="#44506C" Margin="0,0,0,6" />
                    <TextBox x:Name="NumberTextBox" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="12,0,12,16">
                    <TextBlock Text="Дата" FontSize="13" FontWeight="SemiBold" Foreground="#44506C" Margin="0,0,0,6" />
                    <DatePicker x:Name="DocumentDatePicker" Height="40" FontSize="14" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="12,0,0,16">
                    <TextBlock Text="Статус" FontSize="13" FontWeight="SemiBold" Foreground="#44506C" Margin="0,0,0,6" />
                    <ComboBox x:Name="StatusComboBox" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,16">
                    <TextBlock Text="Склад-источник" FontSize="13" FontWeight="SemiBold" Foreground="#44506C" Margin="0,0,0,6" />
                    <ComboBox x:Name="SourceWarehouseComboBox" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,0,12,16">
                    <TextBlock x:Name="TargetWarehouseLabelText" Text="Склад-получатель" FontSize="13" FontWeight="SemiBold" Foreground="#44506C" Margin="0,0,0,6" />
                    <ComboBox x:Name="TargetWarehouseComboBox" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2" Margin="12,0,0,16">
                    <TextBlock Text="Основание / ссылка" FontSize="13" FontWeight="SemiBold" Foreground="#44506C" Margin="0,0,0,6" />
                    <TextBox x:Name="RelatedDocumentTextBox" />
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                    <TextBlock Text="Комментарий" FontSize="13" FontWeight="SemiBold" Foreground="#44506C" Margin="0,0,0,6" />
                    <TextBox x:Name="CommentTextBox" Height="86" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="Позиции документа" FontSize="24" FontWeight="SemiBold" Foreground="#1B2440" />
                    <TextBlock x:Name="LinesSubtitleText" Margin="0,6,0,0" FontSize="14" Foreground="#6E7B98" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,14">
                    <Button Content="Добавить позицию" Style="{StaticResource GhostButtonStyle}" Margin="0,0,10,0" Click="HandleAddLineClick" />
                    <Button Content="Изменить позицию" Style="{StaticResource GhostButtonStyle}" Margin="0,0,10,0" Click="HandleEditLineClick" />
                    <Button Content="Удалить позицию" Style="{StaticResource GhostButtonStyle}" Click="HandleRemoveLineClick" />
                </StackPanel>

                <DataGrid x:Name="LinesGrid" Grid.Row="2" SelectionChanged="HandleLinesSelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Код" Binding="{Binding ItemCode}" Width="1.2*" />
                        <DataGridTextColumn Header="Номенклатура" Binding="{Binding ItemName}" Width="2.5*" />
                        <DataGridTextColumn Header="Ед." Binding="{Binding Unit}" Width="0.8*" />
                        <DataGridTextColumn Header="Количество" Binding="{Binding Quantity, StringFormat=N2}" Width="1*" />
                        <DataGridTextColumn Header="Источник" Binding="{Binding SourceLocation}" Width="1.6*" />
                        <DataGridTextColumn Header="Назначение" Binding="{Binding TargetLocation}" Width="1.6*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <DockPanel Grid.Row="3" Margin="0,18,0,0">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock x:Name="TotalText"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#1B2440" />
                <TextBlock x:Name="ValidationText"
                           Margin="0,6,0,0"
                           FontSize="13"
                           Foreground="#D04D4D" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Style="{StaticResource GhostButtonStyle}" Margin="0,0,10,0" Click="HandleCancelClick" />
                <Button Content="Сохранить" Style="{StaticResource PrimaryButtonStyle}" Click="HandleSaveClick" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
