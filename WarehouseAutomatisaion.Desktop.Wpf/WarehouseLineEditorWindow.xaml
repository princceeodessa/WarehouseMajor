<Window x:Class="WarehouseAutomatisaion.Desktop.Wpf.WarehouseLineEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Позиция склада"
        Width="760"
        Height="470"
        MinWidth="700"
        MinHeight="430"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F6F8FC">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border" BasedOn="{StaticResource DialogCardStyle}">
            <Setter Property="BorderBrush" Value="#E8EDF7" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource DialogFieldLabelStyle}" />

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogPrimaryButtonStyle}" />

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogSecondaryButtonStyle}" />

        <Style TargetType="TextBox" BasedOn="{StaticResource DialogTextBoxStyle}" />

        <Style TargetType="ComboBox" BasedOn="{StaticResource DialogComboBoxStyle}">
            <Setter Property="IsEditable" Value="True" />
            <Setter Property="IsTextSearchEnabled" Value="False" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock x:Name="HeaderTitleText"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="#1B2440" />
            <TextBlock x:Name="HeaderSubtitleText"
                       Margin="0,8,0,0"
                       FontSize="14"
                       Foreground="#6E7B98"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,16">
                    <TextBlock Text="Номенклатура" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="ItemComboBox"
                              DisplayMemberPath="Name"
                              SelectionChanged="HandleItemSelectionChanged"
                              LostKeyboardFocus="HandleItemLostFocus" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,16">
                    <TextBlock Text="Код" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="CodeTextBox" IsReadOnly="True" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,16">
                    <TextBlock Text="Единица" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="UnitTextBox" IsReadOnly="True" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,16">
                    <TextBlock x:Name="QuantityLabelText" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="QuantityTextBox" />
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Ячейка / место" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="SourceLocationTextBox" Style="{StaticResource DialogMultilineTextBoxStyle}" Height="88" />
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock x:Name="TargetLocationLabelText" Text="Место назначения" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="TargetLocationTextBox" Style="{StaticResource DialogMultilineTextBoxStyle}" Height="88" />
                </StackPanel>
            </Grid>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,18,0,0">
            <TextBlock x:Name="ValidationText"
                       DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Foreground="#D04D4D"
                       FontSize="13" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Style="{StaticResource GhostButtonStyle}" Margin="0,0,10,0" Click="HandleCancelClick" />
                <Button Content="Сохранить" Style="{StaticResource PrimaryButtonStyle}" Click="HandleSaveClick" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
