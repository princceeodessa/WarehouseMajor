<Window x:Class="WarehouseAutomatisaion.Desktop.Wpf.WarehouseLineEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Позиция склада"
        Width="760"
        Height="470"
        MinWidth="700"
        MinHeight="430"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F6F8FC">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E8EDF7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="Background" Value="#4F5BFF" />
            <Setter Property="BorderBrush" Value="#4F5BFF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D8DFF0" />
            <Setter Property="Foreground" Value="#25324A" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderBrush" Value="#D8DFF0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderBrush" Value="#D8DFF0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="IsEditable" Value="True" />
            <Setter Property="IsTextSearchEnabled" Value="False" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock x:Name="HeaderTitleText"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="#1B2440" />
            <TextBlock x:Name="HeaderSubtitleText"
                       Margin="0,8,0,0"
                       FontSize="14"
                       Foreground="#6E7B98"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,16">
                    <TextBlock Text="Номенклатура" FontSize="13" FontWeight="SemiBold" Foreground="#44506C" Margin="0,0,0,6" />
                    <ComboBox x:Name="ItemComboBox"
                              DisplayMemberPath="Name"
                              SelectionChanged="HandleItemSelectionChanged"
                              LostKeyboardFocus="HandleItemLostFocus" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,16">
                    <TextBlock Text="Код" FontSize="13" FontWeight="SemiBold" Foreground="#44506C" Margin="0,0,0,6" />
                    <TextBox x:Name="CodeTextBox" IsReadOnly="True" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,16">
                    <TextBlock Text="Единица" FontSize="13" FontWeight="SemiBold" Foreground="#44506C" Margin="0,0,0,6" />
                    <TextBox x:Name="UnitTextBox" IsReadOnly="True" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,16">
                    <TextBlock x:Name="QuantityLabelText" FontSize="13" FontWeight="SemiBold" Foreground="#44506C" Margin="0,0,0,6" />
                    <TextBox x:Name="QuantityTextBox" />
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Ячейка / место" FontSize="13" FontWeight="SemiBold" Foreground="#44506C" Margin="0,0,0,6" />
                    <TextBox x:Name="SourceLocationTextBox" Height="88" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" />
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock x:Name="TargetLocationLabelText" Text="Место назначения" FontSize="13" FontWeight="SemiBold" Foreground="#44506C" Margin="0,0,0,6" />
                    <TextBox x:Name="TargetLocationTextBox" Height="88" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" />
                </StackPanel>
            </Grid>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,18,0,0">
            <TextBlock x:Name="ValidationText"
                       DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Foreground="#D04D4D"
                       FontSize="13" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Style="{StaticResource GhostButtonStyle}" Margin="0,0,10,0" Click="HandleCancelClick" />
                <Button Content="Сохранить" Style="{StaticResource PrimaryButtonStyle}" Click="HandleSaveClick" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
