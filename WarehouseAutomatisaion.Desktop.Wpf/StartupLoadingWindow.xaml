<Window x:Class="WarehouseAutomatisaion.Desktop.Wpf.StartupLoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Запуск MajorWarehause"
        Width="460"
        Height="250"
        MinWidth="460"
        MinHeight="250"
        MaxWidth="460"
        MaxHeight="250"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F7FB"
        ShowInTaskbar="False">
    <Grid Margin="26">
        <Border Background="#FFFFFF"
                BorderBrush="#E3EAF6"
                BorderThickness="1"
                CornerRadius="18"
                Padding="26">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="42"
                            Height="42"
                            CornerRadius="14"
                            Background="#4F5BFF">
                        <TextBlock Text="MW"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#FFFFFF" />
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Загрузка системы"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="#17213A" />
                        <TextBlock x:Name="ConnectionText"
                                   Margin="0,4,0,0"
                                   FontSize="12.5"
                                   Foreground="#7A86A5"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>

                <TextBlock x:Name="StatusText"
                           Grid.Row="1"
                           Margin="0,24,0,0"
                           Text="Читаю данные из общей базы..."
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#24314F"
                           TextWrapping="Wrap" />

                <ProgressBar Grid.Row="2"
                             Margin="0,16,0,0"
                             Height="8"
                             IsIndeterminate="True"
                             Foreground="#4F5BFF"
                             Background="#EEF2FF" />

                <TextBlock Grid.Row="3"
                           Margin="0,16,0,0"
                           Text="Первый запуск после обновления может занять несколько минут. Не закрывайте приложение, пока идет чтение данных."
                           FontSize="12.5"
                           Foreground="#6E7B98"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>
    </Grid>
</Window>
