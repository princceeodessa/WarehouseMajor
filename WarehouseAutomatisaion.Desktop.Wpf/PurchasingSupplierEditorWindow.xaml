<Window x:Class="WarehouseAutomatisaion.Desktop.Wpf.PurchasingSupplierEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Поставщик"
        Height="620"
        Width="760"
        WindowStartupLocation="CenterOwner"
        Background="#F7F9FD">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBrush" Color="#F7F9FD" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="LineBrush" Color="#E7ECF7" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#4F5BFF" />
        <SolidColorBrush x:Key="TextBrush" Color="#17213A" />
        <SolidColorBrush x:Key="MutedBrush" Color="#7A86A5" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6E7B98" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DDE5F4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Foreground" Value="#17213A" />
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,0,8,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DDE5F4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Foreground" Value="#17213A" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DDE5F4" />
            <Setter Property="Foreground" Value="#34415F" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PageBrush}" Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="4,0,4,18">
            <TextBlock x:Name="HeaderTitleText" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
            <TextBlock x:Name="HeaderSubtitleText" Margin="0,6,0,0" FontSize="13.5" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,14">
                    <TextBlock Text="Название" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="NameTextBox" Style="{StaticResource TextBoxStyle}" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="12,0,0,14">
                    <TextBlock Text="Код" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="CodeTextBox" Style="{StaticResource TextBoxStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,14">
                    <TextBlock Text="Статус" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="StatusComboBox" Style="{StaticResource ComboBoxStyle}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,0,0,14">
                    <TextBlock Text="ИНН / КПП" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="TaxIdTextBox" Style="{StaticResource TextBoxStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,12,14">
                    <TextBlock Text="Телефон" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="PhoneTextBox" Style="{StaticResource TextBoxStyle}" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="12,0,0,14">
                    <TextBlock Text="E-mail" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="EmailTextBox" Style="{StaticResource TextBoxStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,0,0,14">
                    <TextBlock Text="Договор" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="ContractTextBox" Style="{StaticResource TextBoxStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="4" Grid.ColumnSpan="2">
                    <TextBlock Text="Источник" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="SourceTextBox" Style="{StaticResource TextBoxStyle}" />
                    <TextBlock x:Name="ValidationText" Margin="0,12,0,0" Foreground="#E14B5A" FontSize="12.5" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Отмена" Style="{StaticResource GhostButtonStyle}" Margin="0,0,10,0" Click="HandleCancelClick" />
            <Button Content="Сохранить поставщика" Style="{StaticResource PrimaryButtonStyle}" Click="HandleSaveClick" />
        </StackPanel>
    </Grid>
</Window>
