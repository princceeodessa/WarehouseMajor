<Window x:Class="WarehouseAutomatisaion.Desktop.Wpf.SalesCustomerEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Клиент"
        Width="760"
        Height="620"
        MinWidth="700"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8FC">
    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#6E7B98" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Height" Value="38" />
            <Setter Property="FontSize" Value="13.5" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock x:Name="HeaderTitleText"
                       Text="Новый клиент"
                       FontSize="26"
                       FontWeight="SemiBold"
                       Foreground="#17213A" />
            <TextBlock Text="Карточка клиента для заказов, счетов и отгрузок."
                       Margin="0,6,0,0"
                       FontSize="13.5"
                       Foreground="#6E7B98" />
        </StackPanel>

        <Border Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="#E4EAF5"
                BorderThickness="1"
                CornerRadius="16"
                Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,14">
                        <TextBlock Text="Код" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="CodeTextBox" Style="{StaticResource InputStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,14">
                        <TextBlock Text="Название" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="NameTextBox" Style="{StaticResource InputStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,14">
                        <TextBlock Text="Договор" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="ContractTextBox" Style="{StaticResource InputStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,14">
                        <TextBlock Text="Статус" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="StatusComboBox" Style="{StaticResource InputStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,14">
                        <TextBlock Text="Менеджер" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="ManagerComboBox" Style="{StaticResource InputStyle}" IsEditable="True" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,14">
                        <TextBlock Text="Валюта" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="CurrencyComboBox" Style="{StaticResource InputStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,14">
                        <TextBlock Text="Телефон" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="PhoneTextBox" Style="{StaticResource InputStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,14">
                        <TextBlock Text="E-mail" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="EmailTextBox" Style="{StaticResource InputStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                        <TextBlock Text="Комментарий" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="NotesTextBox"
                                 Height="100"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <TextBlock x:Name="ValidationText"
                       Foreground="#D92D20"
                       VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена"
                        Width="120"
                        Height="40"
                        Margin="0,0,10,0"
                        Click="HandleCancelClick" />
                <Button Content="Сохранить"
                        Width="150"
                        Height="40"
                        Background="#4F5BFF"
                        BorderBrush="#4F5BFF"
                        Foreground="#FFFFFF"
                        FontWeight="SemiBold"
                        Click="HandleSaveClick" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
